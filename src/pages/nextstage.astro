					<span><i data-lucide="video" style="width:14px;height:14px;vertical-align:-2px;margin-right:4px;"></i> Distanciel, enregistre</span>
					<span><i data-lucide="users" style="width:14px;height:14px;vertical-align:-2px;margin-right:4px;"></i> Dirigeants du portefeuille</span>
