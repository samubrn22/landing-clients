		</section>

		<!-- ==================== CLOSING ==================== -->
		<section class="section closing" id="closing">
			<div class="final-glow"></div>
			<div class="container" style="position:relative;z-index:1;">
				<h2 class="reveal">Rendez-vous le <span class="gradient-text">28 mai</span>.</h2>
				<p class="closing-meta reveal">NextStage &times; Kokoro &middot; Webinaire dirigeants &middot; 28 mai 2026</p>
				<div class="signature reveal">
					<p class="signature-name">Samuel Braniste</p>
					<p class="signature-role">Co-fondateur Kokoro &middot; Expert intégration IA</p>
					<a class="signature-cta" href="https://app.lemcal.com/@samuelbraniste/decouverte" target="_blank" rel="noopener">
						<i data-lucide="calendar-plus" style="width:16px;height:16px;vertical-align:-3px;margin-right:6px;"></i>
						Prendre rendez-vous
