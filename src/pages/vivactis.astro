---

---

<html lang="fr">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Vivactis × Kokoro — Industrialiser le BizDev avec l'IA</title>
		<meta name="description" content="Proposition d'accompagnement — Dispositif d'acquisition augmenté par l'IA pour Vivactis Europe. Pilote Suisse & France, scale-up 7 filiales." />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
		<script src="https://unpkg.com/lucide@0.460.0/dist/umd/lucide.min.js" defer></script>
		<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js" defer></script>
		<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js" defer></script>
	</head>
	<body>

		<!-- ==================== HERO ==================== -->
		<section class="hero" id="hero">
			<div class="hero-glow"></div>
			<div class="container">
				<div class="cover-logos">
					<span class="cover-logo">Vivactis</span>
					<span class="cover-x">&times;</span>
					<span class="cover-logo">Kokoro</span>
				</div>
				<p class="hero-eyebrow">Industrialisation du Business Development</p>
				<h1>Transformer votre expertise scientifique<br/>en <span class="gradient-text">croissance prévisible</span>.</h1>
				<p class="hero-sub">Un dispositif d'acquisition augmenté par l'IA, conçu pour une agence européenne de communication scientifique médicale. Pilotage Suisse &amp; France. Déploiement sur les sept filiales Europe.</p>
				<div class="cover-meta">
					<span><i data-lucide="map-pin" style="width:14px;height:14px;vertical-align:-2px;margin-right:4px;"></i> Lausanne · Paris</span>
					<span><i data-lucide="users" style="width:14px;height:14px;vertical-align:-2px;margin-right:4px;"></i> Pilotage : Thierry Weber &amp; Karine Gérin</span>
					<span><i data-lucide="globe" style="width:14px;height:14px;vertical-align:-2px;margin-right:4px;"></i> Scale : 7 filiales Europe</span>
				</div>
			</div>
		</section>

		<!-- ==================== CONTEXTE ==================== -->
		<section class="section" id="contexte">
			<div class="container">
				<p class="section-label reveal">Le contexte</p>
				<h2 class="reveal">Une agence européenne solide,<br/>un moteur commercial à industrialiser</h2>
				<p class="section-sub reveal">Vivactis est reconnue pour son expertise scientifique et sa capacité à porter des produits pharma, medtech et biotech sur le marché européen. Un <strong>rebranding groupe</strong> est en cours. Un moment stratégique pour activer un dispositif d'acquisition à la hauteur de l'ambition européenne.</p>
				<div class="cards-grid cards-3 reveal-group">
					<div class="card reveal">
						<div class="card-num">01</div>
						<div class="card-icon"><i data-lucide="flask-conical"></i></div>
						<h3>Une expertise scientifique rare</h3>
						<p>Market access, formation médicale, études cliniques, communication patients. Cinq domaines, ~160 collaborateurs, une couverture européenne.</p>
					</div>
					<div class="card reveal">
						<div class="card-num">02</div>
						<div class="card-icon"><i data-lucide="sparkles"></i></div>
						<h3>Une culture produit déjà IA-native</h3>
						<p>Coaching de sales reps, digestes d'études scientifiques, chatbot patients. L'IA est intégrée à votre offre — pas encore à votre moteur commercial.</p>
					</div>
					<div class="card reveal">
						<div class="card-num">03</div>
						<div class="card-icon"><i data-lucide="compass"></i></div>
						<h3>Un rebranding européen en cours</h3>
						<p>Une opportunité rare d'activer un signal fort et de structurer, au même moment, un dispositif d'acquisition transverse au groupe.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- ==================== PROBLÈME ==================== -->
		<section class="section" id="probleme">
			<div class="container">
				<p class="section-label reveal">Le constat</p>
				<h2 class="reveal">Quatre contraintes<br/>qui limitent votre croissance</h2>
				<p class="section-sub reveal">Elles ne relèvent pas d'un défaut d'ambition ni de savoir-faire. Elles relèvent d'un <strong>manque d'industrialisation</strong> du dispositif commercial transverse au groupe.</p>
				<div class="check-grid reveal-group">
					<div class="check-item reveal">
						<div class="check-icon"><i data-lucide="hourglass"></i></div>
						<div>
							<h3>Un temps de dirigeant absorbé par le BizDev</h3>
							<p>Une part significative du temps de Thierry et Karine est consommée par des tâches commerciales que d'autres ressources pourraient prendre. C'est du temps stratégique qui manque ailleurs.</p>
						</div>
					</div>
					<div class="check-item reveal">
						<div class="check-icon"><i data-lucide="layers"></i></div>
						<div>
							<h3>Un dispositif hétérogène entre filiales</h3>
							<p>Odoo en Suisse, Excel en France, systèmes in-house ailleurs. Des niveaux de maturité BizDev très différents entre les sept filiales — et donc une performance groupe sous-optimale.</p>
						</div>
					</div>
					<div class="check-item reveal">
						<div class="check-icon"><i data-lucide="linkedin"></i></div>
						<div>
							<h3>Une distribution LinkedIn sous-exploitée</h3>
							<p>Les pages entreprise génèrent peu d'acquisition. L'algorithme favorise les comptes personnels. Sans mobilisation coordonnée des patrons de filiales, la portée reste faible.</p>
						</div>
					</div>
					<div class="check-item reveal">
						<div class="check-icon"><i data-lucide="alert-triangle"></i></div>
						<div>
							<h3>Des premiers essais sans traction</h3>
							<p>Un pilote Waalaxy sur un produit unique n'a pas donné les résultats attendus. La cause n'est pas l'outil : c'est l'absence de stratégie de signaux et de ressources à forte valeur en amont.</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- ==================== NOTRE LECTURE ==================== -->
		<section class="section" id="lecture">
			<div class="why-claude-bg-glow"></div>
			<div class="container" style="position:relative;z-index:1;">
				<p class="section-label reveal">Notre lecture</p>
				<h2 class="reveal">Le levier n'est pas le volume de messages.<br/>C'est le <span class="gradient-text">partage d'une valeur</span>.</h2>
				<p class="section-sub reveal">Les séquences qui performent aujourd'hui ne demandent pas un rendez-vous. Elles <strong>partagent une ressource de valeur</strong> à la bonne personne, au bon moment, et sollicitent son expertise. Le rendez-vous arrive ensuite, naturellement. C'est précisément ce que l'IA permet d'industrialiser — sans dénaturer la relation.</p>
			</div>
		</section>

		<!-- ==================== OBJECTIFS ==================== -->
		<section class="section" id="objectifs">
			<div class="container">
				<p class="section-label reveal">Les objectifs</p>
				<h2 class="reveal">Cinq résultats attendus<br/>sur l'horizon du dispositif</h2>
				<p class="section-sub reveal">Définis ensemble lors de nos échanges. Ils cadrent la mission, les priorités et les indicateurs de succès.</p>
				<div class="cards-grid cards-3 reveal-group">
					<div class="card card--featured reveal">
						<div class="card-num">01</div>
						<div class="card-icon"><i data-lucide="calendar-check"></i></div>
						<h3>Générer des RDV qualifiés</h3>
						<p>Sans logique de cold mass, sans saturation des prospects. Priorité au quali sur le volume.</p>
					</div>
					<div class="card card--featured reveal">
						<div class="card-num">02</div>
						<div class="card-icon"><i data-lucide="megaphone"></i></div>
						<h3>Capitaliser sur le rebranding</h3>
						<p>Transformer la campagne groupe en signal moteur et en flux d'interactions à exploiter.</p>
					</div>
					<div class="card card--featured reveal">
						<div class="card-num">03</div>
						<div class="card-icon"><i data-lucide="network"></i></div>
						<h3>Industrialiser la distribution</h3>
						<p>Via les pages personnelles des patrons de filiales, sur un rythme coordonné, avec du contenu pré-mâché.</p>
					</div>
					<div class="card card--featured reveal">
						<div class="card-num">04</div>
						<div class="card-icon"><i data-lucide="hourglass"></i></div>
						<h3>Libérer du temps commercial</h3>
						<p>Récupérer des heures de direction pour les réallouer à la stratégie, aux partenariats et aux deals structurants.</p>
					</div>
					<div class="card card--featured reveal">
						<div class="card-num">05</div>
						<div class="card-icon"><i data-lucide="book-open"></i></div>
						<h3>Constituer un playbook Europe</h3>
						<p>Formaliser une méthode réplicable sur les sept filiales, pour un déploiement progressif sans repartir de zéro à chaque pays.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- ==================== SOLUTION ==================== -->
		<section class="section" id="solution">
			<div class="container">
				<p class="section-label reveal">Notre proposition</p>
				<h2 class="reveal">Quatre leviers,<br/>un dispositif intégré</h2>
				<p class="section-sub reveal">Nous concevons, déployons et opérons un moteur d'acquisition orchestré avec vos équipes. Le copywriting reste côté Vivactis (stagiaires, petites mains). Nous prenons la stratégie, la mécanique et le pilotage.</p>
				<div class="acte-list">
					<div class="acte-item reveal">
						<div class="acte-icon"><i data-lucide="target"></i></div>
						<div>
							<h3>01 — Stratégie de signaux d'achat</h3>
							<p>Cadrage ICP et personas, consolidation du TAM. Identification et captation systématique des signaux : rebranding en cours, changements de poste dans les comptes cibles, publications scientifiques, engagement sur vos contenus LinkedIn, mouvements pharma et medtech.</p>
						</div>
					</div>
					<div class="acte-item reveal">
						<div class="acte-icon"><i data-lucide="file-text"></i></div>
						<div>
							<h3>02 — Ressources à forte valeur ajoutée</h3>
							<p>Landing pages personnalisées par compte stratégique, articles thématiques, études, synthèses scientifiques. Production accélérée par l'IA : de 5 jours ouvrés par ressource à quelques heures. Logique d'A/B test à grande échelle.</p>
						</div>
					</div>
					<div class="acte-item reveal">
						<div class="acte-icon"><i data-lucide="workflow"></i></div>
						<div>
							<h3>03 — Orchestration multicanale</h3>
							<p>Séquences LinkedIn en priorité. WhatsApp pour la relance qualitative des contacts tièdes. Synchronisation avec les outils CRM existants (Odoo, Excel, systèmes in-house). Pas de cold mail généralisé.</p>
						</div>
					</div>
					<div class="acte-item reveal">
						<div class="acte-icon"><i data-lucide="bar-chart-3"></i></div>
						<div>
							<h3>04 — Pilotage &amp; itération</h3>
							<p>Reporting mensuel. Arbitrages data-driven : on arrête ce qui ne convertit pas, on renforce ce qui performe. Évolution continue des signaux, des messages et des ressources.</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- ==================== MÉTHODE ==================== -->
		<section class="section" id="methode">
			<div class="container">
				<p class="section-label reveal">La méthode</p>
				<h2 class="reveal">Un cycle trimestriel structuré</h2>
				<p class="section-sub reveal">Nous travaillons par cycles de trois mois, avec un temps de mise en place puis une phase d'exploitation continue. Chaque cycle s'achève par une réévaluation et un réalignement sur les priorités du groupe.</p>
				<div class="program-timeline">
					<div class="program-step">
						<div class="program-dot"></div>
						<div class="program-step-card">
							<div class="program-time">Mois 1 · Setup</div>
							<h3>Cadrage &amp; mise en place</h3>
							<p>Ateliers ICP / TAM / signaux. Audit des bases CRM existantes. Sélection des comptes prioritaires. Premières ressources produites. Séquences construites et lancées.</p>
							<div class="program-badges">
								<span class="badge">ICP</span>
								<span class="badge">Signaux</span>
								<span class="badge">Setup CRM</span>
							</div>
						</div>
					</div>
					<div class="program-step">
						<div class="program-dot program-dot--accent"></div>
						<div class="program-step-card program-step-card--accent">
							<div class="program-time">Mois 2 &amp; 3 · Run</div>
							<h3>Opération &amp; itération</h3>
							<p>Pilotage hebdomadaire des séquences. Production continue de ressources. Suivi des conversions et reporting. Arbitrages mensuels. Préparation du trimestre suivant.</p>
							<div class="program-badges">
								<span class="badge">Monitoring</span>
								<span class="badge">A/B test</span>
								<span class="badge">Reporting</span>
							</div>
						</div>
					</div>
					<div class="program-step">
						<div class="program-dot program-dot--green"></div>
						<div class="program-step-card program-step-card--green">
							<div class="program-time">Fin de cycle · Q+1</div>
							<h3>Réévaluation &amp; scale</h3>
							<p>Bilan du cycle écoulé. Consolidation du playbook. Décision sur le scope du cycle suivant. Activation progressive d'une nouvelle filiale.</p>
							<div class="program-badges">
								<span class="badge">Bilan</span>
								<span class="badge">Playbook</span>
								<span class="badge badge--green">Scale Europe</span>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- ==================== ORG ==================== -->
		<section class="section" id="org">
			<div class="container">
				<p class="section-label reveal">L'organisation</p>
				<h2 class="reveal">Une cellule mixte,<br/>Vivactis × Kokoro</h2>
				<p class="section-sub reveal">Nous ne remplaçons pas votre équipe. Nous l'augmentons. Le dispositif est conçu pour rester opérable en interne à l'issue du pilote.</p>
				<div class="next-grid reveal-group">
					<div class="next-card next-card--highlight reveal">
						<h3><i data-lucide="building" style="width:16px;height:16px;vertical-align:-2px;margin-right:6px;color:#2563eb;"></i> Côté Vivactis</h3>
						<ul>
							<li>Sponsorship dirigeants : Thierry Weber &amp; Karine Gérin</li>
							<li>Stagiaires &amp; petites mains : copywriting, relecture, production des posts</li>
							<li>Experts scientifiques mobilisés ponctuellement pour la validation des ressources</li>
							<li>Données CRM et accès aux bases commerciales existantes</li>
						</ul>
					</div>
					<div class="next-card next-card--highlight reveal">
						<h3><i data-lucide="cpu" style="width:16px;height:16px;vertical-align:-2px;margin-right:6px;color:#2563eb;"></i> Côté Kokoro</h3>
						<ul>
							<li>Stratégie d'acquisition et cadrage des signaux</li>
							<li>Production des landing pages et ressources personnalisées</li>
							<li>Construction et orchestration des séquences multicanales</li>
							<li>Reporting, pilotage, itération</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- ==================== INVESTISSEMENT ==================== -->
		<section class="section" id="investissement">
			<div class="why-claude-bg-glow"></div>
			<div class="container" style="position:relative;z-index:1;">
				<p class="section-label reveal">L'investissement</p>
				<h2 class="reveal">Une enveloppe claire,<br/>un engagement mensuel</h2>
				<p class="section-sub reveal">Facturation au temps passé (TJM), sur un volume calibré pour le périmètre du pilote Suisse &amp; France. Réévaluable à chaque fin de trimestre.</p>
				<div class="cards-grid cards-3 reveal-group">
					<div class="card card--featured reveal">
						<div class="card-num">Budget</div>
						<div class="card-icon"><i data-lucide="wallet"></i></div>
						<h3>2 400 € HT / mois</h3>
						<p>Soit environ 3 jours de travail mensuels dédiés au pilotage du dispositif. Pas de frais de setup additionnels.</p>
					</div>
					<div class="card card--featured reveal">
						<div class="card-num">Rythme</div>
						<div class="card-icon"><i data-lucide="repeat"></i></div>
						<h3>Cycle trimestriel</h3>
						<p>1 mois de setup, 2 mois de run. Puis réévaluation en fin de cycle pour ajuster le scope du trimestre suivant.</p>
					</div>
					<div class="card card--featured reveal">
						<div class="card-num">Pilotage</div>
						<div class="card-icon"><i data-lucide="line-chart"></i></div>
						<h3>Reporting mensuel</h3>
						<p>Point de suivi dédié avec Thierry et Karine. Indicateurs de performance, arbitrages, décisions de scope.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- ==================== SCALE ==================== -->
		<section class="section" id="scale">
			<div class="container">
				<p class="section-label reveal">La trajectoire</p>
				<h2 class="reveal">Valider en Suisse &amp; France.<br/>Dupliquer sur les sept filiales.</h2>
				<p class="section-sub reveal">Le pilote produit deux livrables stratégiques : une <strong>traction commerciale mesurable</strong> sur vos deux marchés matures, et un <strong>playbook documenté</strong> directement transposable aux cinq autres filiales européennes.</p>
				<div class="cards-grid cards-3 reveal-group">
					<div class="card card--featured reveal">
						<div class="card-num">01</div>
						<div class="card-icon"><i data-lucide="check-circle-2"></i></div>
						<h3>Preuve de valeur</h3>
						<p>Un dispositif opérationnel, des séquences qui convertissent, un reporting clair. Fondations tangibles pour décider du scale.</p>
					</div>
					<div class="card card--featured reveal">
						<div class="card-num">02</div>
						<div class="card-icon"><i data-lucide="book-open"></i></div>
						<h3>Playbook transférable</h3>
						<p>Méthode, stack, ressources, séquences. Formalisé pour être réplicable par les autres filiales avec un accompagnement réduit.</p>
					</div>
					<div class="card card--featured reveal">
						<div class="card-num">03</div>
						<div class="card-icon"><i data-lucide="trending-up"></i></div>
						<h3>Effet de levier Europe</h3>
						<p>Déploiement progressif sur les sept filiales du groupe, sur une logique pays-par-pays, avec un patron de filiale référent dans chacune.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- ==================== NEXT STEPS ==================== -->
		<section class="section" id="next">
			<div class="container">
				<p class="section-label reveal">Prochaines étapes</p>
				<h2 class="reveal">Ce qui est calé<br/>pour les deux prochaines semaines</h2>
				<div class="next-grid reveal-group">
					<div class="next-card next-card--highlight reveal">
						<h3><i data-lucide="file-signature" style="width:16px;height:16px;vertical-align:-2px;margin-right:6px;color:#2563eb;"></i> Proposition formalisée</h3>
						<ul>
							<li>Transmise à Thierry &amp; Karine après notre échange</li>
							<li>Intègre le périmètre, le planning, la gouvernance</li>
							<li>Conditions commerciales : 2 400 € HT / mois</li>
							<li>Support de discussion pour le comité exécutif</li>
						</ul>
					</div>
					<div class="next-card next-card--highlight reveal">
						<h3><i data-lucide="users" style="width:16px;height:16px;vertical-align:-2px;margin-right:6px;color:#2563eb;"></i> Comité exécutif Vivactis</h3>
						<ul>
							<li>Tenu la semaine prochaine</li>
							<li>Présentation du dispositif aux autres patrons de filiales</li>
							<li>Décision : go / no-go / périmètre ajusté</li>
							<li>Identification des premiers pays relais</li>
						</ul>
					</div>
					<div class="next-card next-card--highlight reveal">
						<h3><i data-lucide="calendar" style="width:16px;height:16px;vertical-align:-2px;margin-right:6px;color:#2563eb;"></i> Point de suivi</h3>
						<ul>
							<li>Mercredi 7 mai 2026 · 13h</li>
							<li>Retour comité exécutif</li>
							<li>Alignement sur le démarrage</li>
							<li>Calage de la première session de cadrage</li>
						</ul>
					</div>
					<div class="next-card reveal">
						<h3><i data-lucide="help-circle" style="width:16px;height:16px;vertical-align:-2px;margin-right:6px;color:hsla(0,0%,100%,.4);"></i> Points à valider ensemble</h3>
						<ul>
							<li>Offres Vivactis à prioriser sur le pilote</li>
							<li>Identification des filiales relais après Suisse &amp; France</li>
							<li>Gouvernance côté Vivactis Europe</li>
							<li>Date de démarrage effectif</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- ==================== CLOSING ==================== -->
		<section class="section closing" id="closing">
			<div class="final-glow"></div>
			<div class="container" style="position:relative;z-index:1;">
				<h2 class="reveal">Un moteur commercial <span class="gradient-text">à la hauteur</span><br/>de votre expertise scientifique.</h2>
				<p class="closing-meta reveal">Vivactis × Kokoro &middot; Proposition d'accompagnement &middot; Avril 2026</p>
			</div>
		</section>

		<!-- JS -->
		<script>
			document.addEventListener('DOMContentLoaded', () => {
				if (window.lucide) lucide.createIcons();

				if (window.gsap && window.ScrollTrigger) {
					gsap.registerPlugin(ScrollTrigger);

					document.querySelectorAll('section').forEach(section => {
						const els = section.querySelectorAll('.reveal');
						if (els.length) {
							gsap.fromTo(els,
								{ opacity: 0, y: 30, filter: 'blur(4px)' },
								{
									opacity: 1, y: 0, filter: 'blur(0px)',
									duration: 0.8,
									stagger: 0.12,
									ease: 'power3.out',
									scrollTrigger: { trigger: section, start: 'top 80%', once: true }
								}
							);
						}
					});

					gsap.fromTo('.cover-logos', { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.7, delay: 0.2, ease: 'power3.out' });
					gsap.fromTo('.hero-eyebrow', { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.7, delay: 0.35, ease: 'power3.out' });
					gsap.fromTo('.hero h1', { opacity: 0, y: 30 }, { opacity: 1, y: 0, duration: 0.8, delay: 0.5, ease: 'power3.out' });
					gsap.fromTo('.hero-sub', { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.7, delay: 0.65, ease: 'power3.out' });
					gsap.fromTo('.cover-meta', { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.7, delay: 0.8, ease: 'power3.out' });

					gsap.fromTo('.program-dot', { opacity: 0, scale: 0 }, {
						opacity: 1, scale: 1, duration: 0.4, stagger: 0.12, ease: 'back.out(2)',
						scrollTrigger: { trigger: '.program-timeline', start: 'top 80%', once: true }
					});

					document.querySelectorAll('.program-step').forEach((step, i) => {
						const card = step.querySelector('.program-step-card');
						const fromX = i % 2 === 0 ? -40 : 40;
						gsap.fromTo(card, { opacity: 0, x: fromX }, {
							opacity: 1, x: 0, duration: 0.6, ease: 'power3.out',
							scrollTrigger: { trigger: step, start: 'top 85%', once: true }
						});
					});
				}
			});
		</script>
	</body>
