---

---

<html lang="fr">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Clinitex × Kokoro — Journée Marketing / RSE / Com · 29 avril</title>
		<meta name="description" content="Programme de la journée IA Clinitex pour les équipes Marketing, RSE et Expérience Client — 29 avril 2026." />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
		<script src="https://unpkg.com/lucide@0.460.0/dist/umd/lucide.min.js" defer></script>
		<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js" defer></script>
		<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js" defer></script>
	</head>
	<body>

		<!-- ==================== COVER ==================== -->
		<section class="hero" id="hero">
			<div class="hero-glow"></div>
			<div class="container">
				<div class="cover-logos">
					<span class="cover-logo">Clinitex</span>
					<span class="cover-x">&times;</span>
					<span class="cover-logo">Kokoro</span>
				</div>
				<p class="hero-eyebrow">Journée Marketing et RSE Clinitex</p>
				<h1>Rendre le monde <span class="gradient-text">plus beau</span>.</h1>
				<div class="cover-meta">
					<span><i data-lucide="calendar" style="width:14px;height:14px;vertical-align:-2px;margin-right:4px;"></i> 29 avril 2026</span>
					<span><i data-lucide="clock" style="width:14px;height:14px;vertical-align:-2px;margin-right:4px;"></i> 9h &ndash; 17h</span>
					<span><i data-lucide="map-pin" style="width:14px;height:14px;vertical-align:-2px;margin-right:4px;"></i> Villeneuve d'Ascq</span>
					<span><i data-lucide="users" style="width:14px;height:14px;vertical-align:-2px;margin-right:4px;"></i> 4 participants</span>
				</div>
			</div>
		</section>

		<!-- ==================== LES 4 AXES ==================== -->
		<section class="section" id="concept">
			<div class="why-claude-bg-glow"></div>
			<div class="container" style="position:relative;z-index:1;">
				<p class="section-label reveal">Le fil rouge</p>
				<h2 class="reveal">4 axes, un service</h2>
				<p class="section-sub reveal">Partir de ce qui est <strong>remonté par les équipes</strong> dans le formulaire, et le mettre en pratique sur vos vraies données.</p>
				<div class="cards-grid cards-3 reveal-group" style="grid-template-columns: repeat(2, 1fr); max-width: 780px; margin: 0 auto;">
					<div class="card card--featured reveal">
						<div class="card-num">01</div>
						<div class="card-icon"><i data-lucide="radar"></i></div>
						<h3>Veille stratégique</h3>
						<p>Normes RSE, ECOVADIS, communication des concurrents. Skills + Routines Claude pour automatiser.</p>
					</div>
					<div class="card card--featured reveal">
						<div class="card-num">02</div>
						<div class="card-icon"><i data-lucide="pen-tool"></i></div>
						<h3>Production de contenu</h3>
						<p>SEO / GEO en priorité. Trames de podcasts pour la radio Clinitex. Démo Claude Design.</p>
					</div>
					<div class="card card--featured reveal">
						<div class="card-num">03</div>
						<div class="card-icon"><i data-lucide="mail"></i></div>
						<h3>Expérience client &amp; com</h3>
						<p>Emails et SMS via PrimoTexto, pilotés depuis Claude. Rédaction, séquences, personnalisation.</p>
					</div>
					<div class="card card--featured reveal">
						<div class="card-num">04</div>
						<div class="card-icon"><i data-lucide="bar-chart-3"></i></div>
						<h3>Analyse &amp; reporting</h3>
						<p>Metabase, Pegas, enquêtes RC / Satisfaction. Live Artifacts = dashboards auto-actualisés.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- ==================== SETUP ==================== -->
		<section class="section" id="setup">
			<div class="container">
				<p class="section-label reveal">Setup</p>
				<h2 class="reveal">Ce qu'on vérifie avant 9h</h2>
				<p class="section-sub reveal">Les 4 participants n'ont pas fait la journée d'acculturation du COPIL. On prépare tout en amont pour <strong>ne perdre aucune minute le 29</strong>.</p>
				<div class="check-grid reveal-group">
					<div class="check-item reveal">
						<div class="check-icon"><i data-lucide="user-check"></i></div>
						<div>
							<h3>Comptes Claude</h3>
							<p>Les 4 participants ont un accès, identifiants testés, paramétrages validés.</p>
						</div>
					</div>
					<div class="check-item reveal">
						<div class="check-icon"><i data-lucide="database"></i></div>
						<div>
							<h3>Connecteur Metabase</h3>
							<p>Activé côté admin Claude. Chaque participant se connecte via le connecteur natif.</p>
						</div>
					</div>
					<div class="check-item reveal">
						<div class="check-icon"><i data-lucide="sparkles"></i></div>
						<div>
							<h3>Fonctionnalités avancées</h3>
							<p>Live Artifacts activés, Claude Design accessible (preview), Routines disponibles.</p>
						</div>
					</div>
					<div class="check-item reveal">
						<div class="check-icon"><i data-lucide="projector"></i></div>
						<div>
							<h3>Salle &amp; équipement</h3>
							<p>Configuration en U, vidéoprojecteur, adaptateurs. Ordis prêts à 9h.</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- ==================== TIMELINE ==================== -->
		<section class="section" id="timeline">
			<div class="container">
				<p class="section-label reveal">Déroulé</p>
				<h2 class="reveal">La journée, heure par heure</h2>
				<div class="program-timeline">
					<div class="program-step">
						<div class="program-dot"></div>
						<div class="program-step-card">
							<div class="program-time">9h00</div>
							<h3>Ouverture</h3>
							<p>Tour de table, retours formulaire, fil rouge. Activation Claude pour chaque participant.</p>
						</div>
					</div>
					<div class="program-step">
						<div class="program-dot"></div>
						<div class="program-step-card">
							<div class="program-time">9h30</div>
							<h3>Acculturation</h3>
							<p>Écosystème IA, pourquoi Claude, rédaction de prompts, confidentialité. Premier test sur un vrai contenu Clinitex.</p>
							<div class="program-badges">
								<span class="badge">Chat</span>
								<span class="badge">Prompting</span>
							</div>
						</div>
					</div>
					<div class="program-step">
						<div class="program-dot program-dot--accent"></div>
						<div class="program-step-card program-step-card--accent">
							<div class="program-time">11h00</div>
							<h3>Acte 1 — Veille stratégique</h3>
							<p>Construction d'un Skill de veille (RSE, ECOVADIS, concurrents). Activation via Routine hebdomadaire.</p>
							<div class="program-badges">
								<span class="badge">Skills</span>
								<span class="badge">Routines</span>
								<span class="badge">Web</span>
							</div>
						</div>
					</div>
					<div class="program-step">
						<div class="program-dot program-dot--muted"></div>
						<div class="program-step-card">
							<div class="program-time">12h30</div>
							<h3>Déjeuner</h3>
						</div>
					</div>
					<div class="program-step">
						<div class="program-dot program-dot--accent"></div>
						<div class="program-step-card program-step-card--accent">
							<div class="program-time">14h00</div>
							<h3>Acte 2 — Production de contenu</h3>
							<p>SEO / GEO sur un vrai sujet Clinitex. Trames podcast "radio Clinitex". Démo Claude Design + culture ReMotion.</p>
							<div class="program-badges">
								<span class="badge">Artifacts</span>
								<span class="badge">Claude Design</span>
								<span class="badge">Web</span>
							</div>
						</div>
					</div>
					<div class="program-step">
						<div class="program-dot program-dot--accent"></div>
						<div class="program-step-card program-step-card--accent">
							<div class="program-time">15h30</div>
							<h3>Acte 3 — Expérience client &amp; com</h3>
							<p>Intégration API PrimoTexto dans Claude : rédaction, séquences, pilotage des envois email / SMS depuis Claude.</p>
							<div class="program-badges">
								<span class="badge">API</span>
								<span class="badge">PrimoTexto</span>
								<span class="badge">Chat</span>
							</div>
						</div>
					</div>
					<div class="program-step">
						<div class="program-dot program-dot--green"></div>
						<div class="program-step-card program-step-card--green">
							<div class="program-time">16h15</div>
							<h3>Acte 4 — Analyse &amp; reporting</h3>
							<p>Connecteur Metabase, audit Pegas, enquêtes RC / Satisfaction. Live Artifacts pour des dashboards auto-actualisés.</p>
							<div class="program-badges">
								<span class="badge">Metabase</span>
								<span class="badge badge--green">Live Artifacts</span>
							</div>
						</div>
					</div>
					<div class="program-step">
						<div class="program-dot"></div>
						<div class="program-step-card">
							<div class="program-time">16h45</div>
							<h3>Clôture</h3>
							<p>Feuille de route perso (3 actions à activer la semaine suivante) + Q&A.</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- ==================== ACTE 1 — VEILLE ==================== -->
		<section class="section" id="acte1">
			<div class="container">
				<p class="section-label reveal">Acte 1</p>
				<h2 class="reveal">Veille <span class="gradient-text">stratégique</span></h2>
				<p class="section-sub reveal">Rester documenté sans y passer ses matinées.</p>
				<div class="acte-list">
					<div class="acte-item reveal">
						<div class="acte-icon"><i data-lucide="leaf"></i></div>
						<div>
							<h3>"Je veille sur les normes RSE"</h3>
							<p>Skill qui surveille les évolutions ECOVADIS et les réglementations RSE clés. Vous choisissez les sujets à tracker.</p>
						</div>
					</div>
					<div class="acte-item reveal">
						<div class="acte-icon"><i data-lucide="eye"></i></div>
						<div>
							<h3>"Je surveille les concurrents"</h3>
							<p>Veille sur les communications des concurrents : LinkedIn, site web, presse. Vous choisissez qui est suivi.</p>
						</div>
					</div>
					<div class="acte-item reveal">
						<div class="acte-icon"><i data-lucide="calendar-clock"></i></div>
						<div>
							<h3>"Je veux que ça tourne tout seul"</h3>
							<p>Routine Claude programmée : tous les lundis 9h, la veille est dans ta boîte. On la met en place ensemble.</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- ==================== ACTE 2 — CONTENU ==================== -->
		<section class="section" id="acte2">
			<div class="container">
				<p class="section-label reveal">Acte 2</p>
				<h2 class="reveal">Production de <span class="gradient-text">contenu</span></h2>
				<p class="section-sub reveal">Idéation, trame, production. Trois phases, un workflow.</p>
				<div class="acte-list">
					<div class="acte-item reveal">
						<div class="acte-icon"><i data-lucide="search"></i></div>
						<div>
							<h3>"Je travaille mon SEO / GEO"</h3>
							<p>Sur un vrai sujet Clinitex : recherche de mots-clés, brief éditorial, plan de contenu, rédaction optimisée.</p>
						</div>
					</div>
					<div class="acte-item reveal">
						<div class="acte-icon"><i data-lucide="mic"></i></div>
						<div>
							<h3>"Je prépare la radio Clinitex"</h3>
							<p>Trames récurrentes par thématique, angles, questions pour les invités. Préparation, pas montage.</p>
						</div>
					</div>
					<div class="acte-item reveal">
						<div class="acte-icon"><i data-lucide="palette"></i></div>
						<div>
							<h3>"Je veux des livrables chartés"</h3>
							<p>Démo Claude Design (preview) : on injecte la charte Clinitex, on génère un slide deck PDF/PPT chartée en un prompt.</p>
						</div>
					</div>
					<div class="acte-item reveal">
						<div class="acte-icon"><i data-lucide="film"></i></div>
						<div>
							<h3>Culture : ReMotion</h3>
							<p>Extension Claude pour le montage vidéo automatique. Exploratoire — on montre où ça en est, pas un outil à déployer aujourd'hui.</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- ==================== ACTE 3 — EXPÉRIENCE CLIENT ==================== -->
		<section class="section" id="acte3">
			<div class="container">
				<p class="section-label reveal">Acte 3</p>
				<h2 class="reveal">Expérience <span class="gradient-text">client &amp; com</span></h2>
				<p class="section-sub reveal">Claude en supervision, PrimoTexto en exécution.</p>
				<div class="acte-list">
					<div class="acte-item reveal">
						<div class="acte-icon"><i data-lucide="link"></i></div>
						<div>
							<h3>Connecter PrimoTexto à Claude</h3>
							<p>Authentification par clé API (header <code>X-Primotexto-ApiKey</code>). Endpoint <code>POST /v2/marketing/campaigns</code> pour créer des campagnes SMS directement depuis Claude.</p>
						</div>
					</div>
					<div class="acte-item reveal">
						<div class="acte-icon"><i data-lucide="message-square-text"></i></div>
						<div>
							<h3>"Je rédige une campagne SMS"</h3>
							<p>Claude rédige le message avec variables de personnalisation (<code>${"${prenom}"}</code>, <code>${"${agence}"}</code>), gère les 150 caractères SMS, et crée la campagne sur une liste de contacts PrimoTexto existante.</p>
						</div>
					</div>
					<div class="acte-item reveal">
						<div class="acte-icon"><i data-lucide="calendar-clock"></i></div>
						<div>
							<h3>"Je programme l'envoi"</h3>
							<p>Campagne créée avec date d'envoi (timestamp), sourceAddress personnalisé. Modération PrimoTexto avant délivrance. Claude supervise l'idéation et la production, PrimoTexto exécute.</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- ==================== ACTE 4 — REPORTING ==================== -->
		<section class="section" id="acte4">
			<div class="container">
				<p class="section-label reveal">Acte 4</p>
				<h2 class="reveal">Analyse &amp; <span class="gradient-text">reporting</span></h2>
				<p class="section-sub reveal">La data Pegas est déjà dans Metabase. Claude s'y connecte nativement.</p>
				<div class="acte-list">
					<div class="acte-item reveal">
						<div class="acte-icon"><i data-lucide="shield-check"></i></div>
						<div>
							<h3>"J'audite mes données Pegas"</h3>
							<p>Via le connecteur Metabase. Détection des manquements, génération du plan d'action.</p>
						</div>
					</div>
					<div class="acte-item reveal">
						<div class="acte-icon"><i data-lucide="message-square"></i></div>
						<div>
							<h3>"J'analyse les enquêtes RC / Satisfaction"</h3>
							<p>Détection des signaux faibles, évolutions de satisfaction, problématiques récurrentes.</p>
						</div>
					</div>
					<div class="acte-item reveal">
						<div class="acte-icon"><i data-lucide="activity"></i></div>
						<div>
							<h3>"Mon dashboard se met à jour tout seul"</h3>
							<p>Live Artifacts : on crée un dashboard une fois, Claude le refresh automatiquement. Sorti la semaine dernière.</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- ==================== NEXT STEPS ==================== -->
		<section class="section" id="next">
			<div class="why-claude-bg-glow"></div>
			<div class="container" style="position:relative;z-index:1;">
				<p class="section-label reveal">Préparation</p>
				<h2 class="reveal">Ce qu'il me faut en amont</h2>
				<div class="next-grid reveal-group">
					<div class="next-card next-card--highlight reveal">
						<h3><i data-lucide="database" style="width:16px;height:16px;vertical-align:-2px;margin-right:6px;color:#4D9DE0;"></i> Data</h3>
						<ul>
							<li>Export Metabase — tables de faits + dimensions utilisées côté marketing / exp client</li>
							<li>Échantillon Pegas anonymisé par agence (via Metabase)</li>
							<li>Enquêtes RC + Satisfaction types, anonymisées</li>
						</ul>
					</div>
					<div class="next-card next-card--highlight reveal">
						<h3><i data-lucide="megaphone" style="width:16px;height:16px;vertical-align:-2px;margin-right:6px;color:#4D9DE0;"></i> Contenu &amp; com</h3>
						<ul>
							<li>Charte graphique Clinitex (logo, couleurs, polices) pour Claude Design</li>
							<li>2-3 contenus SEO / GEO récents + brief éditorial si dispo</li>
							<li>Exemples de campagnes PrimoTexto déjà envoyées</li>
							<li>Clé API PrimoTexto + ID d'une liste de contacts test</li>
							<li>Sujets envisagés pour la radio Clinitex</li>
						</ul>
					</div>
					<div class="next-card next-card--highlight reveal">
						<h3><i data-lucide="leaf" style="width:16px;height:16px;vertical-align:-2px;margin-right:6px;color:#4D9DE0;"></i> RSE</h3>
						<ul>
							<li>Liste des normes suivies (ECOVADIS + autres)</li>
							<li>Liste des concurrents à surveiller</li>
							<li>Dernier rapport RSE publié</li>
						</ul>
					</div>
					<div class="next-card reveal">
						<h3><i data-lucide="check-circle" style="width:16px;height:16px;vertical-align:-2px;margin-right:6px;color:hsla(0,0%,100%,.4);"></i> Logistique</h3>
						<ul>
							<li>Prépa des postes la veille, ordis prêts à 9h</li>
							<li>Activation des fonctionnalités Claude (comme au COPIL)</li>
							<li>Confirmer si je squatte les bureaux jeudi 30</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- ==================== CLOSING ==================== -->
		<section class="section closing" id="closing">
			<div class="final-glow"></div>
			<div class="container" style="position:relative;z-index:1;">
				<h2 class="reveal">Rendez-vous le <span class="gradient-text">29 avril</span> !</h2>
				<p class="closing-meta reveal">Clinitex &times; Kokoro &middot; Marketing / RSE / Com &middot; 29 avril 2026</p>
			</div>
		</section>

		<!-- JS -->
		<script>
			document.addEventListener('DOMContentLoaded', () => {
				if (window.lucide) lucide.createIcons();
				if (window.gsap && window.ScrollTrigger) {
					gsap.registerPlugin(ScrollTrigger);
					document.querySelectorAll('section').forEach(section => {
						const els = section.querySelectorAll('.reveal');
						if (els.length) {
							gsap.fromTo(els,
								{ opacity: 0, y: 30, filter: 'blur(4px)' },
								{ opacity: 1, y: 0, filter: 'blur(0px)', duration: 0.8, stagger: 0.12, ease: 'power3.out',
								  scrollTrigger: { trigger: section, start: 'top 80%', once: true } });
						}
					});
					gsap.fromTo('.cover-logos', { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.7, delay: 0.2, ease: 'power3.out' });
					gsap.fromTo('.hero-eyebrow', { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.7, delay: 0.35, ease: 'power3.out' });
					gsap.fromTo('.hero h1', { opacity: 0, y: 30 }, { opacity: 1, y: 0, duration: 0.8, delay: 0.5, ease: 'power3.out' });
					gsap.fromTo('.cover-meta', { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.7, delay: 0.7, ease: 'power3.out' });
					gsap.fromTo('.program-dot', { opacity: 0, scale: 0 },
						{ opacity: 1, scale: 1, duration: 0.4, stagger: 0.12, ease: 'back.out(2)',
						  scrollTrigger: { trigger: '.program-timeline', start: 'top 80%', once: true } });
					document.querySelectorAll('.program-step').forEach((step, i) => {
						const card = step.querySelector('.program-step-card');
						const fromX = i % 2 === 0 ? -40 : 40;
						gsap.fromTo(card, { opacity: 0, x: fromX },
							{ opacity: 1, x: 0, duration: 0.6, ease: 'power3.out',
							  scrollTrigger: { trigger: step, start: 'top 85%', once: true } });
					});
				}
			});
		</script>
	</body>
</html>

<style>
	* { margin: 0; padding: 0; box-sizing: border-box; }
	html { scroll-behavior: smooth; }
	body { font-family: 'Inter', -apple-system, system-ui, sans-serif; background: #0A0812; color: hsla(0,0%,100%,.6); line-height: 1.7; -webkit-font-smoothing: antialiased; }
	.container { max-width: 1000px; margin: 0 auto; padding: 0 28px; }
	.reveal { opacity: 0; }
	h1, h2 { font-family: 'Inter', sans-serif; font-weight: 800; letter-spacing: -0.04em; }
	h3 { font-family: 'Inter', sans-serif; font-weight: 700; letter-spacing: -0.01em; }
	.gradient-text { background: linear-gradient(135deg, #4D9DE0, #0055A4, #7EC8E3); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
	.section-label { font-size: 11px; text-transform: uppercase; letter-spacing: 5px; color: #4D9DE0; font-weight: 600; text-align: center; margin-bottom: 20px; }
	.section-sub { font-size: 17px; color: hsla(0,0%,100%,.55); max-width: 650px; margin: -32px auto 64px; text-align: center; line-height: 1.7; }
	.section-sub strong { color: hsla(0,0%,100%,.9); }
	.section { padding: 130px 0; position: relative; overflow: hidden; }
	h2 { font-size: clamp(28px, 5vw, 48px); font-weight: 800; color: #fff; margin-bottom: 64px; text-align: center; line-height: 1.1; }
