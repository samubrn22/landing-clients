---

---

<html lang="fr">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<title>Baromètre MICE 2026 — Gouvernance des Meetings & Événements · OneMice</title>
		<meta name="description" content="50% des dépenses M&E échappent à tout pilotage. Le Baromètre MICE 2026 analyse les failles structurelles et les leviers de gouvernance." />
		<meta property="og:title" content="Baromètre MICE 2026 — Gouvernance des Meetings & Événements" />
		<meta property="og:description" content="50% des dépenses M&E échappent à tout pilotage. Analyse structurelle et leviers de gouvernance." />
		<meta property="og:type" content="website" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
		<style>
			*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

			:root {
				--bg: #0B0F1A;
				--bg-elevated: #111827;
				--bg-card: rgba(59,130,246,0.04);
				--accent: #3B82F6;
				--accent-light: #60A5FA;
				--accent-glow: rgba(59,130,246,0.25);
				--accent-soft: rgba(59,130,246,0.08);
				--accent-border: rgba(59,130,246,0.15);
				--cyan: #22D3EE;
				--cyan-glow: rgba(34,211,238,0.2);
				--text: #E8ECF4;
				--text-sub: rgba(232,236,244,0.6);
				--text-muted: rgba(232,236,244,0.35);
				--border: rgba(59,130,246,0.12);
				--font: 'Inter', -apple-system, system-ui, sans-serif;
			}

			html { scroll-behavior: smooth; }
			body {
				font-family: var(--font);
				background: var(--bg);
				color: var(--text);
				line-height: 1.6;
				-webkit-font-smoothing: antialiased;
			}

			/* ── HERO ── */
			.hero {
				position: relative;
				min-height: 100vh;
				display: flex;
				align-items: center;
				justify-content: center;
				padding: 80px 56px;
				overflow: hidden;
				text-align: center;
			}
			/* Blueprint grid */
			.hero::before {
				content: '';
				position: absolute;
				inset: 0;
				background-image:
					linear-gradient(rgba(59,130,246,0.04) 1px, transparent 1px),
					linear-gradient(90deg, rgba(59,130,246,0.04) 1px, transparent 1px);
				background-size: 80px 80px;
				pointer-events: none;
			}
			.hero::after {
				content: '';
				position: absolute;
				top: -20%;
				left: 50%;
				transform: translateX(-50%);
				width: 800px;
				height: 800px;
				background: radial-gradient(circle, rgba(59,130,246,0.08) 0%, transparent 70%);
				pointer-events: none;
			}

			.hero-content {
				position: relative;
				z-index: 2;
				max-width: 720px;
			}

			.hero-badge {
				display: inline-block;
				font-size: 12px;
				font-weight: 600;
				color: var(--cyan);
				border: 1px solid var(--cyan-glow);
				background: rgba(34,211,238,0.06);
				padding: 8px 18px;
				border-radius: 6px;
				margin-bottom: 36px;
				letter-spacing: 0.08em;
				text-transform: uppercase;
			}

			.hero-stat {
				font-size: clamp(56px, 8vw, 96px);
				font-weight: 900;
				color: var(--accent-light);
				line-height: 1;
				letter-spacing: -0.04em;
				margin-bottom: 16px;
			}

			.hero h1 {
				font-size: clamp(28px, 3.5vw, 42px);
				font-weight: 800;
				color: var(--text);
				line-height: 1.2;
				letter-spacing: -0.04em;
				margin-bottom: 24px;
			}

			.hero-sub {
				font-size: 17px;
				color: var(--text-sub);
				line-height: 1.7;
				margin-bottom: 40px;
				max-width: 560px;
				margin-left: auto;
				margin-right: auto;
			}

			.btn-primary {
				display: inline-flex;
				align-items: center;
				gap: 10px;
				padding: 16px 32px;
				background: var(--accent);
				color: #fff;
				border: none;
				border-radius: 8px;
				font-family: var(--font);
				font-size: 16px;
				font-weight: 600;
				cursor: pointer;
				transition: all 0.2s;
				text-decoration: none;
			}
			.btn-primary:hover {
				background: var(--accent-light);
				transform: translateY(-1px);
				box-shadow: 0 8px 28px var(--accent-glow);
			}

			/* ── STATS BAR ── */
			.stats {
				background: var(--bg-elevated);
				border-top: 1px solid var(--border);
				border-bottom: 1px solid var(--border);
				padding: 48px 56px;
			}
			.stats-row {
				max-width: 1000px;
				margin: 0 auto;
				display: grid;
				grid-template-columns: repeat(4, 1fr);
				gap: 32px;
			}
			.stat-item { text-align: center; }
			.stat-num {
				font-size: 32px;
				font-weight: 900;
				color: var(--accent-light);
				letter-spacing: -0.03em;
				line-height: 1;
				margin-bottom: 8px;
			}
			.stat-label {
				font-size: 13px;
				color: var(--text-sub);
				line-height: 1.5;
			}

			/* ── DISCOVER ── */
			.discover {
				position: relative;
				max-width: 1100px;
				margin: 0 auto;
				padding: 120px 56px;
			}
			/* Blueprint grid */
			.discover::before {
				content: '';
				position: absolute;
				inset: 0;
				background-image:
					linear-gradient(rgba(59,130,246,0.03) 1px, transparent 1px),
					linear-gradient(90deg, rgba(59,130,246,0.03) 1px, transparent 1px);
				background-size: 80px 80px;
				pointer-events: none;
			}

			.discover-header {
				text-align: center;
				margin-bottom: 64px;
				position: relative;
			}
			.discover-header h2 {
				font-size: clamp(28px, 4vw, 44px);
				font-weight: 800;
				color: var(--text);
				letter-spacing: -0.04em;
				margin-bottom: 14px;
			}
			.discover-header p {
				font-size: 16px;
				color: var(--text-sub);
			}

			.cards-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 16px;
				position: relative;
			}
			.cards-row-2 {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 16px;
				margin-top: 16px;
				position: relative;
			}

			.card {
				position: relative;
				padding: 32px 28px;
				background: var(--bg-card);
				border: 1px solid var(--border);
				border-radius: 14px;
				backdrop-filter: blur(8px);
				-webkit-backdrop-filter: blur(8px);
				overflow: hidden;
				transition: all 0.3s cubic-bezier(0.16,1,0.3,1);
			}
			.card:hover {
				border-color: var(--accent-border);
				background: rgba(59,130,246,0.07);
				transform: translateY(-3px);
				box-shadow: 0 8px 32px rgba(0,0,0,0.3);
			}

			.card-num {
				position: absolute;
				top: 12px; right: 20px;
				font-size: 64px;
				font-weight: 900;
				color: rgba(59,130,246,0.06);
				line-height: 1;
				pointer-events: none;
				letter-spacing: -0.04em;
			}

			.card-icon {
				width: 42px; height: 42px;
				display: flex;
				align-items: center;
				justify-content: center;
				background: var(--accent-soft);
				border: 1px solid var(--accent-border);
				border-radius: 10px;
				color: var(--accent-light);
				margin-bottom: 20px;
			}

			.card-data {
				display: inline-block;
				font-size: 12px;
				font-weight: 600;
				color: var(--cyan);
				background: rgba(34,211,238,0.06);
				border: 1px solid var(--cyan-glow);
				padding: 4px 10px;
				border-radius: 100px;
				margin-bottom: 14px;
			}

			.card h3 {
				font-size: 17px;
				font-weight: 700;
				color: var(--text);
				margin-bottom: 8px;
				letter-spacing: -0.02em;
				line-height: 1.35;
			}
			.card p {
				font-size: 14px;
				color: var(--text-sub);
				line-height: 1.65;
			}

			/* ── CTA SECTION ── */
			.cta {
				background: var(--bg-elevated);
				border-top: 1px solid var(--border);
				padding: 100px 56px;
				text-align: center;
				position: relative;
				overflow: hidden;
			}
			.cta::before {
				content: '';
				position: absolute;
				top: 0; left: 0; right: 0;
				height: 2px;
				background: linear-gradient(90deg, transparent, var(--accent), var(--cyan), var(--accent), transparent);
			}
			/* Blueprint grid */
			.cta::after {
				content: '';
				position: absolute;
				inset: 0;
				background-image:
					linear-gradient(rgba(59,130,246,0.03) 1px, transparent 1px),
					linear-gradient(90deg, rgba(59,130,246,0.03) 1px, transparent 1px);
				background-size: 80px 80px;
				pointer-events: none;
			}

			.cta-inner { position: relative; z-index: 1; }

			.cta-icon {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				width: 56px; height: 56px;
				margin-bottom: 28px;
				color: var(--accent-light);
			}

			.cta h2 {
				font-size: clamp(26px, 3.5vw, 38px);
				font-weight: 800;
				color: var(--text);
				margin-bottom: 14px;
				letter-spacing: -0.03em;
			}
			.cta-sub {
				font-size: 16px;
				color: var(--text-sub);
				margin-bottom: 40px;
				max-width: 480px;
				margin-left: auto;
				margin-right: auto;
				line-height: 1.6;
			}

			.cta-form {
				display: flex;
				flex-direction: column;
				gap: 14px;
				max-width: 460px;
				margin: 0 auto 20px;
			}
			.cta-form input {
				width: 100%;
				padding: 16px 20px;
				background: rgba(59,130,246,0.04);
				border: 1px solid var(--border);
				border-radius: 10px;
				font-family: var(--font);
				font-size: 15px;
				color: var(--text);
				outline: none;
				transition: all 0.2s;
			}
			.cta-form input::placeholder { color: var(--text-muted); }
			.cta-form input:focus {
				border-color: var(--accent);
				box-shadow: 0 0 0 3px rgba(59,130,246,0.08);
			}

			.cta-form .btn-primary {
				width: 100%;
				justify-content: center;
				padding: 18px;
				font-size: 16px;
			}

			.cta-specs {
				display: flex;
				justify-content: center;
				gap: 24px;
				margin-top: 20px;
				flex-wrap: wrap;
			}
			.cta-spec {
				display: flex;
				align-items: center;
				gap: 6px;
				font-size: 12px;
				color: var(--text-muted);
			}
			.cta-spec svg { color: var(--cyan); flex-shrink: 0; }

			.form-ok {
				display: none;
				max-width: 460px;
				margin: 0 auto;
				padding: 24px;
				background: rgba(34,211,238,0.06);
				border: 1px solid var(--cyan-glow);
				border-radius: 10px;
				color: var(--cyan);
				font-size: 15px;
				font-weight: 500;
			}

			/* ── FOOTER ── */
			.footer {
				padding: 24px 56px;
				text-align: center;
				font-size: 13px;
				color: var(--text-muted);
				border-top: 1px solid var(--border);
			}
			.footer a { color: var(--text-muted); text-decoration: none; }
			.footer a:hover { color: var(--text-sub); }

			/* ── RESPONSIVE ── */
			@media (max-width: 768px) {
				.hero { padding: 60px 24px; min-height: auto; }
				.hero-stat { font-size: 56px; }
				.hero h1 { font-size: 24px; }
				.hero-sub { font-size: 16px; }

				.stats { padding: 32px 24px; }
				.stats-row { grid-template-columns: repeat(2, 1fr); gap: 24px; }

				.discover { padding: 60px 24px; }
				.cards-grid { grid-template-columns: 1fr; }
				.cards-row-2 { grid-template-columns: 1fr; }

				.cta { padding: 60px 24px 80px; }
				.cta-specs { flex-direction: column; align-items: center; gap: 12px; }
			}
		</style>
	</head>

	<body>
		<!-- HERO -->
		<section class="hero">
			<div class="hero-content">
				<span class="hero-badge ha">Baromètre MICE · Édition 2026</span>
				<div class="hero-stat ha">50%</div>
				<h1 class="ha">de vos dépenses Meetings & Événements échappent à tout pilotage</h1>
				<p class="hero-sub ha">Le Baromètre MICE 2026 analyse les failles structurelles de la gouvernance M&E et les leviers pour y remédier. 15 pages. Données terrain.</p>
				<a href="#cta-form" class="btn-primary ha">Recevoir le baromètre <span>&darr;</span></a>
			</div>
		</section>

		<!-- STATS BAR -->
		<section class="stats">
			<div class="stats-row">
				<div class="stat-item rv">
					<div class="stat-num">20-40%</div>
					<div class="stat-label">de surcoût lié à la fragmentation</div>
				</div>
				<div class="stat-item rv">
					<div class="stat-num">84%</div>
					<div class="stat-label">de processus encore manuels</div>
				</div>
				<div class="stat-item rv">
					<div class="stat-num">10-30%</div>
					<div class="stat-label">d'économies avec une gouvernance structurée</div>
				</div>
				<div class="stat-item rv">
					<div class="stat-num">+20 ans</div>
					<div class="stat-label">d'expertise MICE terrain</div>
				</div>
			</div>
		</section>

		<!-- CE QUE VOUS DÉCOUVRIREZ -->
		<section class="discover">
			<div class="discover-header">
				<h2 class="rv">Ce que vous trouverez dans ce baromètre</h2>
				<p class="rv">6 chapitres. Des données sourcées. Un auto-diagnostic pour évaluer votre maturité.</p>
			</div>

			<div class="cards-grid">
				<div class="card rv">
					<span class="card-num">01</span>
					<div class="card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div>
					<h3>Un territoire sans propriétaire</h3>
					<p>Travel, achats, finance, com, RH — tout le monde touche aux M&E, personne ne les structure. Zone grise organisationnelle.</p>
				</div>
				<div class="card rv">
					<span class="card-num">02</span>
					<div class="card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
					<span class="card-data">20-40% surcoût</span>
					<h3>Le coût réel de l'absence de gouvernance</h3>
					<p>50% des dépenses sans pilotage. 20-40% de surcoût lié à la fragmentation. Chaque chiffre est sourcé.</p>
				</div>
				<div class="card rv">
					<span class="card-num">03</span>
					<div class="card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><circle cx="6" cy="6" r="1"/><circle cx="6" cy="18" r="1"/></svg></div>
					<span class="card-data">84% manuels</span>
					<h3>Pourquoi personne ne structure</h3>
					<p>84% de processus encore manuels. Légitimité politique. Autonomie des équipes. Zone de confort.</p>
				</div>
			</div>
			<div class="cards-row-2">
				<div class="card rv">
					<span class="card-num">04</span>
					<div class="card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2a4 4 0 0 0-4 4c0 2 2 3 2 6h4c0-3 2-4 2-6a4 4 0 0 0-4-4z"/><line x1="10" y1="16" x2="14" y2="16"/><line x1="10" y1="19" x2="14" y2="19"/><line x1="11" y1="22" x2="13" y2="22"/></svg></div>
					<span class="card-data">10-30% éco.</span>
					<h3>Ce que change la gouvernance</h3>
					<p>10-30% d'économies. Visibilité consolidée. Compliance. Pilotage par la donnée.</p>
				</div>
				<div class="card rv">
					<span class="card-num">05</span>
					<div class="card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="m16 12-4-4-4 4"/><path d="M12 16V8"/></svg></div>
					<h3>4 sphères concurrentielles, 1 vide</h3>
					<p>Travel & Expense, SMM, Agences, ERP — et un espace vacant : la gouvernance systémique.</p>
				</div>
				<div class="card rv">
					<span class="card-num">06</span>
					<div class="card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg></div>
					<h3>Auto-diagnostic : où en êtes-vous ?</h3>
					<p>10 questions pour évaluer votre maturité en gouvernance M&E. Scoring inclus.</p>
				</div>
			</div>
		</section>

		<!-- CTA -->
		<section class="cta">
			<div class="cta-inner">
				<div class="cta-icon"><svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg></div>
				<h2 class="rv">Recevez votre baromètre</h2>
				<p class="cta-sub rv">15 pages d'analyse structurelle, données terrain 2025-2026, et un auto-diagnostic pour évaluer votre gouvernance M&E.</p>
				<form class="cta-form rv" data-form="onemice-lead" action="#" id="cta-form">
					<input type="text" name="prenom" placeholder="Votre prénom" required />
					<input type="email" name="email" placeholder="Votre email professionnel" required />
					<input type="text" name="entreprise" placeholder="Votre entreprise (optionnel)" />
					<button type="submit" class="btn-primary">Recevoir le baromètre <span>&darr;</span></button>
				</form>
				<div class="form-ok" id="cta-ok">Merci ! Vous recevrez le baromètre dans les prochaines minutes.</div>
				<div class="cta-specs rv">
					<span class="cta-spec">
						<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
						PDF · 15 pages
					</span>
					<span class="cta-spec">
						<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
						Données terrain 2025-2026
					</span>
					<span class="cta-spec">
						<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
						Auto-diagnostic inclus
					</span>
				</div>
			</div>
		</section>

		<!-- FOOTER -->
		<footer class="footer">
			<p>&copy; 2026 OneMice &middot; Structure What Matters &middot; <a href="#">Politique de confidentialit&eacute;</a></p>
		</footer>

		<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
		<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
		<script>
			gsap.registerPlugin(ScrollTrigger);
			gsap.from('.ha', { opacity:0, y:32, duration:0.9, stagger:0.15, ease:'power2.out', delay:0.3 });
			document.querySelectorAll('.rv').forEach(el => {
				gsap.from(el, {
					scrollTrigger: { trigger:el, start:'top 92%', toggleActions:'play none none none' },
					opacity:0, y:24, duration:0.7,
					delay: el.closest('.cards-grid,.cards-row-2,.stats-row') ? [...el.parentElement.children].indexOf(el)*0.1 : 0,
					ease:'power2.out'
				});
			});
			const f=document.getElementById('cta-form'),s=document.getElementById('cta-ok');
			f.addEventListener('submit',e=>{
				e.preventDefault();
				const b=f.querySelector('button');b.textContent='Envoi...';b.disabled=true;
				setTimeout(()=>{
					gsap.to(f,{opacity:0,y:-8,duration:0.25,onComplete:()=>{
						f.style.display='none';s.style.display='block';
						gsap.from(s,{opacity:0,y:8,duration:0.3});
					}});
				},500);
			});
		</script>
	</body>
</html>
