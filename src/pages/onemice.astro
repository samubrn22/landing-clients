---

<html lang="fr">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<title>Baromètre MICE 2026 — Gouvernance des Meetings & Événements · OneMice</title>
		<meta name="description" content="50% des dépenses M&E échappent à tout pilotage. Le Baromètre MICE 2026 analyse les failles structurelles et les leviers de gouvernance." />
		<meta property="og:title" content="Baromètre MICE 2026 — Gouvernance des Meetings & Événements" />
		<meta property="og:description" content="50% des dépenses M&E échappent à tout pilotage. Analyse structurelle et leviers de gouvernance." />
		<meta property="og:type" content="website" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
		<style>
			*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

			:root {
				--bg: #0B0F1A;
				--bg-elevated: #111827;
				--bg-card: rgba(91,158,143,0.04);
				--teal: #5B9E8F;
				--teal-light: #7AB8AA;
				--teal-glow: rgba(91,158,143,0.25);
				--teal-soft: rgba(91,158,143,0.08);
				--teal-border: rgba(91,158,143,0.18);
				--blue: #3B82F6;
				--blue-soft: rgba(59,130,246,0.06);
				--text: #E8ECF4;
				--text-sub: rgba(232,236,244,0.6);
				--text-muted: rgba(232,236,244,0.35);
				--border: rgba(91,158,143,0.12);
				--font: 'Inter', -apple-system, system-ui, sans-serif;
			}

			html { scroll-behavior: smooth; }
			body {
				font-family: var(--font);
				background: var(--bg);
				color: var(--text);
				line-height: 1.6;
				-webkit-font-smoothing: antialiased;
			}

			/* ── NAV ── */
			.nav {
				position: fixed;
				top: 0; left: 0; right: 0;
				z-index: 100;
				padding: 18px 56px;
				display: flex;
				align-items: center;
				justify-content: space-between;
				background: rgba(11,15,26,0.85);
				backdrop-filter: blur(16px);
				-webkit-backdrop-filter: blur(16px);
				border-bottom: 1px solid var(--border);
				transform: translateY(-100%);
				transition: transform 0.3s;
			}
			.nav.visible { transform: translateY(0); }
			.nav-logo {
				font-size: 15px;
				font-weight: 700;
				color: var(--teal-light);
				letter-spacing: 0.06em;
				text-transform: uppercase;
			}
			.nav-cta {
				display: inline-flex;
				align-items: center;
				gap: 8px;
				padding: 10px 22px;
				background: var(--teal);
				color: #fff;
				border: none;
				border-radius: 6px;
				font-family: var(--font);
				font-size: 13px;
				font-weight: 600;
				cursor: pointer;
				text-decoration: none;
				transition: all 0.2s;
			}
			.nav-cta:hover { background: var(--teal-light); }

			/* ── HERO ── */
			.hero {
				position: relative;
				min-height: 100vh;
				display: flex;
				align-items: center;
				justify-content: center;
				padding: 120px 56px 100px;
				overflow: hidden;
				text-align: center;
			}
			/* Subtle grid */
			.hero::before {
				content: '';
				position: absolute;
				inset: 0;
				background-image:
					linear-gradient(rgba(91,158,143,0.03) 1px, transparent 1px),
					linear-gradient(90deg, rgba(91,158,143,0.03) 1px, transparent 1px);
				background-size: 80px 80px;
				pointer-events: none;
			}
			/* Radial glow */
			.hero::after {
				content: '';
				position: absolute;
				top: -20%;
				left: 50%;
				transform: translateX(-50%);
				width: 800px;
				height: 800px;
				background: radial-gradient(circle, rgba(91,158,143,0.08) 0%, transparent 70%);
				pointer-events: none;
			}

			.hero-content {
				position: relative;
				z-index: 2;
				max-width: 720px;
			}

			.hero-badge {
				display: inline-block;
				font-size: 11px;
				font-weight: 600;
				color: var(--teal-light);
				border: 1px solid var(--teal-border);
				background: var(--teal-soft);
				padding: 8px 20px;
				border-radius: 100px;
				margin-bottom: 40px;
				letter-spacing: 0.1em;
				text-transform: uppercase;
			}

			.hero-stat {
				font-size: clamp(56px, 8vw, 96px);
				font-weight: 800;
				color: var(--teal-light);
				line-height: 1;
				letter-spacing: -0.04em;
				margin-bottom: 16px;
			}

			.hero h1 {
				font-size: clamp(28px, 3.5vw, 42px);
				font-weight: 700;
				color: var(--text);
				line-height: 1.25;
				letter-spacing: -0.03em;
				margin-bottom: 24px;
			}

			.hero-sub {
				font-size: 17px;
				color: var(--text-sub);
				line-height: 1.7;
				margin-bottom: 44px;
				max-width: 560px;
				margin-left: auto;
				margin-right: auto;
			}

			.btn-primary {
				display: inline-flex;
				align-items: center;
				gap: 10px;
				padding: 16px 36px;
				background: var(--teal);
				color: #fff;
				border: none;
				border-radius: 8px;
				font-family: var(--font);
				font-size: 15px;
				font-weight: 600;
				cursor: pointer;
				transition: all 0.25s;
				text-decoration: none;
			}
			.btn-primary:hover {
				background: var(--teal-light);
				transform: translateY(-2px);
				box-shadow: 0 8px 28px var(--teal-glow);
			}

			/* ── STATS BAR ── */
			.stats {
				background: var(--bg-elevated);
				border-top: 1px solid var(--border);
				border-bottom: 1px solid var(--border);
				padding: 48px 56px;
			}
			.stats-row {
				max-width: 1000px;
				margin: 0 auto;
				display: grid;
				grid-template-columns: repeat(4, 1fr);
				gap: 32px;
			}
			.stat-item {
				text-align: center;
			}
			.stat-num {
				font-size: 32px;
				font-weight: 800;
				color: var(--teal-light);
				letter-spacing: -0.03em;
				line-height: 1;
				margin-bottom: 8px;
			}
			.stat-label {
				font-size: 13px;
				color: var(--text-sub);
				line-height: 1.5;
			}

			/* ── SOMMAIRE ── */
			.sommaire {
				position: relative;
				max-width: 860px;
				margin: 0 auto;
				padding: 100px 56px;
			}

			.section-label {
				font-size: 11px;
				font-weight: 600;
				color: var(--teal);
				letter-spacing: 0.12em;
				text-transform: uppercase;
				margin-bottom: 16px;
			}

			.sommaire h2 {
				font-size: clamp(26px, 3.5vw, 38px);
				font-weight: 700;
				color: var(--text);
				letter-spacing: -0.03em;
				margin-bottom: 56px;
				max-width: 520px;
				line-height: 1.2;
			}

			.chapters {
				display: flex;
				flex-direction: column;
				gap: 0;
			}

			.chapter {
				display: grid;
				grid-template-columns: 56px 1fr auto;
				gap: 24px;
				align-items: center;
				padding: 28px 16px;
				border-bottom: 1px solid var(--border);
				transition: all 0.2s;
				border-radius: 6px;
			}
			.chapter:first-child { border-top: 1px solid var(--border); }
			.chapter:hover {
				background: var(--teal-soft);
			}

			.chapter-num {
				font-size: 28px;
				font-weight: 800;
				color: rgba(91,158,143,0.3);
				line-height: 1;
			}

			.chapter-content h3 {
				font-size: 16px;
				font-weight: 600;
				color: var(--text);
				margin-bottom: 4px;
				line-height: 1.4;
			}
			.chapter-content p {
				font-size: 14px;
				color: var(--text-sub);
				line-height: 1.6;
			}

			.chapter-data {
				font-size: 13px;
				font-weight: 600;
				color: var(--teal-light);
				white-space: nowrap;
				background: var(--teal-soft);
				padding: 6px 14px;
				border-radius: 100px;
				border: 1px solid var(--teal-border);
			}

			/* ── DIAGNOSTIC ── */
			.diagnostic {
				background: var(--bg-elevated);
				border-top: 1px solid var(--border);
				border-bottom: 1px solid var(--border);
				padding: 100px 56px;
			}
			.diagnostic-inner {
				max-width: 860px;
				margin: 0 auto;
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 64px;
				align-items: center;
			}
			.diagnostic-left h2 {
				font-size: clamp(24px, 3vw, 34px);
				font-weight: 700;
				color: var(--text);
				letter-spacing: -0.03em;
				margin-bottom: 20px;
				line-height: 1.2;
			}
			.diagnostic-left p {
				font-size: 15px;
				color: var(--text-sub);
				line-height: 1.7;
				margin-bottom: 12px;
			}

			.diag-questions {
				display: flex;
				flex-direction: column;
				gap: 12px;
			}
			.diag-q {
				display: flex;
				align-items: flex-start;
				gap: 12px;
				padding: 16px 20px;
				background: var(--bg-card);
				border: 1px solid var(--border);
				border-radius: 8px;
				font-size: 14px;
				color: var(--text-sub);
				line-height: 1.5;
				transition: all 0.2s;
			}
			.diag-q:hover {
				border-color: var(--teal-border);
				background: var(--teal-soft);
			}
			.diag-q-num {
				font-weight: 700;
				color: var(--teal);
				flex-shrink: 0;
				min-width: 20px;
			}

			/* ── CTA SECTION ── */
			.cta {
				padding: 100px 56px;
				position: relative;
				overflow: hidden;
			}
			.cta::before {
				content: '';
				position: absolute;
				inset: 0;
				background-image:
					linear-gradient(rgba(91,158,143,0.03) 1px, transparent 1px),
					linear-gradient(90deg, rgba(91,158,143,0.03) 1px, transparent 1px);
				background-size: 80px 80px;
				pointer-events: none;
			}

			.cta-inner {
				position: relative;
				z-index: 1;
				max-width: 520px;
				margin: 0 auto;
				text-align: center;
			}

			.cta h2 {
				font-size: clamp(26px, 3.5vw, 36px);
				font-weight: 700;
				color: var(--text);
				margin-bottom: 14px;
				letter-spacing: -0.03em;
				line-height: 1.2;
			}
			.cta-sub {
				font-size: 15px;
				color: var(--text-sub);
				margin-bottom: 40px;
				line-height: 1.7;
			}

			.cta-form {
				display: flex;
				flex-direction: column;
				gap: 14px;
				max-width: 420px;
				margin: 0 auto 20px;
				text-align: left;
			}
			.cta-form label {
				font-size: 11px;
				font-weight: 600;
				color: var(--text-sub);
				letter-spacing: 0.06em;
				text-transform: uppercase;
				margin-bottom: -8px;
			}
			.cta-form input {
				width: 100%;
				padding: 14px 18px;
				background: rgba(91,158,143,0.04);
				border: 1px solid var(--border);
				border-radius: 8px;
				font-family: var(--font);
				font-size: 15px;
				color: var(--text);
				outline: none;
				transition: all 0.2s;
			}
			.cta-form input::placeholder { color: var(--text-muted); }
			.cta-form input:focus {
				border-color: var(--teal);
				box-shadow: 0 0 0 3px rgba(91,158,143,0.1);
			}

			.cta-form .btn-primary {
				width: 100%;
				justify-content: center;
				padding: 16px;
				margin-top: 4px;
			}

			.cta-specs {
				display: flex;
				justify-content: center;
				gap: 24px;
				margin-top: 24px;
				flex-wrap: wrap;
			}
			.cta-spec {
				display: flex;
				align-items: center;
				gap: 6px;
				font-size: 12px;
				color: var(--text-muted);
			}
			.cta-spec svg { color: var(--teal); flex-shrink: 0; }

			.form-ok {
				display: none;
				max-width: 420px;
				margin: 0 auto;
				padding: 24px;
				background: var(--teal-soft);
				border: 1px solid var(--teal-border);
				border-radius: 8px;
				color: var(--teal-light);
				font-size: 15px;
				font-weight: 500;
			}

			/* ── FOOTER ── */
			.footer {
				padding: 28px 56px;
				text-align: center;
				font-size: 12px;
				color: var(--text-muted);
				border-top: 1px solid var(--border);
			}
			.footer a { color: var(--text-muted); text-decoration: none; }
			.footer a:hover { color: var(--text-sub); }

			/* ── RESPONSIVE ── */
			@media (max-width: 768px) {
				.nav { padding: 14px 24px; }
				.hero { padding: 100px 24px 60px; min-height: auto; }
				.hero-stat { font-size: 56px; }
				.hero h1 { font-size: 26px; }

				.stats { padding: 32px 24px; }
				.stats-row { grid-template-columns: repeat(2, 1fr); gap: 24px; }

				.sommaire { padding: 60px 24px; }
				.chapter { grid-template-columns: 40px 1fr; gap: 16px; padding: 20px 8px; }
				.chapter-data { display: none; }

				.diagnostic { padding: 60px 24px; }
				.diagnostic-inner { grid-template-columns: 1fr; gap: 40px; }

				.cta { padding: 60px 24px 80px; }
				.cta-specs { flex-direction: column; align-items: center; gap: 12px; }
			}
		</style>
	</head>

	<body>
		<!-- NAV -->
		<nav class="nav" id="nav">
			<span class="nav-logo">OneMice</span>
			<a href="#cta-section" class="nav-cta">Recevoir le baromètre</a>
		</nav>

		<!-- HERO -->
		<section class="hero">
			<div class="hero-content">
				<span class="hero-badge ha">Baromètre MICE · Édition 2026</span>
				<div class="hero-stat ha">50%</div>
				<h1 class="ha">de vos dépenses Meetings & Événements échappent à tout pilotage</h1>
				<p class="hero-sub ha">Le Baromètre MICE 2026 analyse les failles structurelles de la gouvernance M&E et les leviers pour y remédier. 15 pages. Données terrain.</p>
				<a href="#cta-section" class="btn-primary ha">Recevoir le baromètre <span>&darr;</span></a>
			</div>
		</section>

		<!-- STATS BAR -->
		<section class="stats">
			<div class="stats-row">
				<div class="stat-item rv">
					<div class="stat-num">20-40%</div>
					<div class="stat-label">de surcoût lié à la fragmentation</div>
				</div>
				<div class="stat-item rv">
					<div class="stat-num">84%</div>
					<div class="stat-label">de processus encore manuels</div>
				</div>
				<div class="stat-item rv">
					<div class="stat-num">10-30%</div>
					<div class="stat-label">d'économies avec une gouvernance structurée</div>
				</div>
				<div class="stat-item rv">
					<div class="stat-num">+20 ans</div>
					<div class="stat-label">d'expertise MICE terrain</div>
				</div>
			</div>
		</section>

		<!-- SOMMAIRE -->
		<section class="sommaire">
			<p class="section-label rv">Sommaire</p>
			<h2 class="rv">Ce que vous trouverez dans ce baromètre</h2>

			<div class="chapters">
				<div class="chapter rv">
					<span class="chapter-num">01</span>
					<div class="chapter-content">
						<h3>Le vrai problème : un territoire sans propriétaire</h3>
						<p>Travel, achats, finance, com, RH — tout le monde touche au sujet, personne ne le structure.</p>
					</div>
					<span class="chapter-data">Zone grise</span>
				</div>
				<div class="chapter rv">
					<span class="chapter-num">02</span>
					<div class="chapter-content">
						<h3>Le coût réel de l'absence de gouvernance</h3>
						<p>50% des dépenses sans pilotage. 20-40% de surcoût. Chaque chiffre est sourcé.</p>
					</div>
					<span class="chapter-data">20-40% surcoût</span>
				</div>
				<div class="chapter rv">
					<span class="chapter-num">03</span>
					<div class="chapter-content">
						<h3>Pourquoi personne ne structure</h3>
						<p>84% de processus manuels. Légitimité politique. Autonomie des équipes. Zone de confort.</p>
					</div>
					<span class="chapter-data">84% manuels</span>
				</div>
				<div class="chapter rv">
					<span class="chapter-num">04</span>
					<div class="chapter-content">
						<h3>Ce que change la gouvernance</h3>
						<p>10-30% d'économies. Visibilité consolidée. Compliance. Pilotage par la donnée.</p>
					</div>
					<span class="chapter-data">10-30% éco.</span>
				</div>
				<div class="chapter rv">
					<span class="chapter-num">05</span>
					<div class="chapter-content">
						<h3>Paysage concurrentiel : 4 sphères, 1 vide</h3>
						<p>Travel & Expense, SMM, Agences, ERP — et un espace vacant : la gouvernance systémique.</p>
					</div>
					<span class="chapter-data">4 sphères</span>
				</div>
				<div class="chapter rv">
					<span class="chapter-num">06</span>
					<div class="chapter-content">
						<h3>Auto-diagnostic : où en êtes-vous ?</h3>
						<p>10 questions pour évaluer votre niveau de maturité en gouvernance M&E.</p>
					</div>
					<span class="chapter-data">10 questions</span>
				</div>
			</div>
		</section>

		<!-- DIAGNOSTIC TEASER -->
		<section class="diagnostic">
			<div class="diagnostic-inner">
				<div class="diagnostic-left rv">
					<p class="section-label">Auto-diagnostic</p>
					<h2>Évaluez votre maturité en gouvernance M&E</h2>
					<p>Le baromètre inclut un auto-diagnostic en 10 questions. Voici un aperçu :</p>
				</div>
				<div class="diag-questions">
					<div class="diag-q rv">
						<span class="diag-q-num">01</span>
						<span>Avez-vous une visibilité consolidée sur l'ensemble de vos dépenses M&E ?</span>
					</div>
					<div class="diag-q rv">
						<span class="diag-q-num">04</span>
						<span>Vos processus de validation sont-ils digitalisés ou encore manuels ?</span>
					</div>
					<div class="diag-q rv">
						<span class="diag-q-num">07</span>
						<span>Disposez-vous d'un référentiel fournisseurs structuré et à jour ?</span>
					</div>
					<div class="diag-q rv">
						<span class="diag-q-num">10</span>
						<span>Pouvez-vous produire un reporting M&E fiable en moins de 48h ?</span>
					</div>
				</div>
			</div>
		</section>

		<!-- CTA -->
		<section class="cta" id="cta-section">
			<div class="cta-inner">
				<p class="section-label rv">Baromètre 2026</p>
				<h2 class="rv">Recevez votre exemplaire</h2>
				<p class="cta-sub rv">15 pages d'analyse structurelle, données terrain 2025-2026, et un auto-diagnostic pour évaluer votre gouvernance M&E.</p>
				<form class="cta-form rv" data-form="onemice-lead" action="#" id="cta-form">
					<label for="f-prenom">Prénom</label>
					<input type="text" id="f-prenom" name="prenom" placeholder="Votre prénom" required />
					<label for="f-email">Email professionnel</label>
					<input type="email" id="f-email" name="email" placeholder="prenom@entreprise.com" required />
					<label for="f-entreprise">Entreprise <span style="font-weight:400;text-transform:none;letter-spacing:0">(optionnel)</span></label>
					<input type="text" id="f-entreprise" name="entreprise" placeholder="Nom de votre entreprise" />
					<button type="submit" class="btn-primary">Recevoir le baromètre</button>
				</form>
				<div class="form-ok" id="cta-ok">Merci ! Vous recevrez le baromètre dans les prochaines minutes.</div>
				<div class="cta-specs rv">
					<span class="cta-spec">
						<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
						PDF · 15 pages
					</span>
					<span class="cta-spec">
						<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
						Données terrain
					</span>
					<span class="cta-spec">
						<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
						Auto-diagnostic inclus
					</span>
				</div>
			</div>
		</section>

		<!-- FOOTER -->
		<footer class="footer">
			<p>&copy; 2026 OneMice &middot; Structure What Matters &middot; <a href="#">Politique de confidentialit&eacute;</a></p>
		</footer>

		<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
		<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
		<script>
			gsap.registerPlugin(ScrollTrigger);

			// Hero animations
			gsap.from('.ha', { opacity:0, y:36, duration:0.9, stagger:0.18, ease:'power2.out', delay:0.3 });

			// Scroll reveals
			document.querySelectorAll('.rv').forEach(el => {
				gsap.from(el, {
					scrollTrigger: { trigger:el, start:'top 90%', toggleActions:'play none none none' },
					opacity:0, y:20, duration:0.6,
					delay: el.closest('.chapters,.diag-questions,.stats-row') ? [...el.parentElement.children].indexOf(el)*0.08 : 0,
					ease:'power2.out'
				});
			});

			// Stat counter animation
			document.querySelectorAll('.stat-num').forEach(el => {
				gsap.from(el, {
					scrollTrigger: { trigger:el, start:'top 90%' },
					textContent: 0,
					duration: 1.2,
					ease: 'power2.out',
					snap: { textContent: 1 },
					onUpdate: function() {}
				});
			});

			// Nav on scroll
			const nav = document.getElementById('nav');
			ScrollTrigger.create({
				start: 'top -400',
				onUpdate: (self) => {
					nav.classList.toggle('visible', self.progress > 0);
				}
			});

			// Form
			const f=document.getElementById('cta-form'),s=document.getElementById('cta-ok');
			f.addEventListener('submit',e=>{
				e.preventDefault();
				const b=f.querySelector('button');b.textContent='Envoi...';b.disabled=true;
				setTimeout(()=>{
					gsap.to(f,{opacity:0,y:-8,duration:0.25,onComplete:()=>{
						f.style.display='none';s.style.display='block';
						gsap.from(s,{opacity:0,y:8,duration:0.3});
					}});
				},500);
			});
		</script>
	</body>
</html>
