---

---

<html lang="fr">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<title>Les 5 angles morts du MICE en 2026 · OneMice</title>
		<meta name="description" content="Guide gratuit : les 5 failles structurelles qui coûtent des millions aux organisations. Meetings & events, gouvernance, dépenses." />
		<meta property="og:title" content="Les 5 angles morts du MICE en 2026" />
		<meta property="og:description" content="Un guide pour les décideurs qui veulent structurer la gouvernance de leurs meetings & events." />
		<meta property="og:type" content="website" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
		<style>
			*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

			:root {
				--bg: #0B0F1A;
				--bg-elevated: #111827;
				--bg-card: rgba(59,130,246,0.04);
				--accent: #3B82F6;
				--accent-light: #60A5FA;
				--accent-glow: rgba(59,130,246,0.25);
				--accent-soft: rgba(59,130,246,0.08);
				--accent-border: rgba(59,130,246,0.15);
				--cyan: #22D3EE;
				--cyan-glow: rgba(34,211,238,0.2);
				--text: #E8ECF4;
				--text-sub: rgba(232,236,244,0.6);
				--text-muted: rgba(232,236,244,0.35);
				--border: rgba(59,130,246,0.12);
				--font: 'Inter', -apple-system, system-ui, sans-serif;
			}

			html { scroll-behavior: smooth; }
			body {
				font-family: var(--font);
				background: var(--bg);
				color: var(--text);
				line-height: 1.6;
				-webkit-font-smoothing: antialiased;
			}

			/* ── HERO ── */
			.hero {
				position: relative;
				min-height: 100vh;
				display: flex;
				align-items: flex-end;
				padding: 60px 56px 80px;
				overflow: hidden;
			}
			.hero-bg {
				position: absolute;
				inset: 0;
				background:
					url('https://images.unsplash.com/photo-1540575467063-178a50c2df87?w=1920&q=80&auto=format')
					center center / cover no-repeat;
			}
			.hero-bg::after {
				content: '';
				position: absolute;
				inset: 0;
				background: linear-gradient(
					to right,
					rgba(11,15,26,0.92) 0%,
					rgba(11,15,26,0.78) 40%,
					rgba(11,15,26,0.4) 100%
				);
			}
			/* Blueprint grid over hero */
			.hero-bg::before {
				content: '';
				position: absolute;
				inset: 0;
				z-index: 1;
				background-image:
					linear-gradient(rgba(59,130,246,0.04) 1px, transparent 1px),
					linear-gradient(90deg, rgba(59,130,246,0.04) 1px, transparent 1px);
				background-size: 80px 80px;
				pointer-events: none;
			}

			.hero-content {
				position: relative;
				z-index: 2;
				max-width: 640px;
			}

			.hero-badge {
				display: inline-block;
				font-size: 12px;
				font-weight: 600;
				color: var(--cyan);
				border: 1px solid var(--cyan-glow);
				background: rgba(34,211,238,0.06);
				padding: 8px 18px;
				border-radius: 6px;
				margin-bottom: 36px;
				letter-spacing: 0.08em;
				text-transform: uppercase;
			}

			.hero h1 {
				font-size: clamp(40px, 5.5vw, 62px);
				font-weight: 900;
				color: var(--text);
				line-height: 1.08;
				letter-spacing: -0.04em;
				margin-bottom: 24px;
			}
			.hero h1 .h1-accent {
				color: var(--accent-light);
			}

			.hero-sub {
				font-size: 18px;
				color: var(--text-sub);
				line-height: 1.7;
				margin-bottom: 40px;
				max-width: 520px;
			}

			.btn-primary {
				display: inline-flex;
				align-items: center;
				gap: 10px;
				padding: 16px 32px;
				background: var(--accent);
				color: #fff;
				border: none;
				border-radius: 8px;
				font-family: var(--font);
				font-size: 16px;
				font-weight: 600;
				cursor: pointer;
				transition: all 0.2s;
				text-decoration: none;
			}
			.btn-primary:hover {
				background: var(--accent-light);
				transform: translateY(-1px);
				box-shadow: 0 8px 28px var(--accent-glow);
			}

			/* ── TRUST BAR ── */
			.trust {
				background: var(--bg-elevated);
				border-top: 1px solid var(--border);
				border-bottom: 1px solid var(--border);
				padding: 32px 56px;
			}
			.trust-row {
				max-width: 1100px;
				margin: 0 auto;
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 56px;
				flex-wrap: wrap;
			}
			.trust-item {
				display: flex;
				align-items: center;
				gap: 12px;
				font-size: 14px;
				color: var(--text-sub);
			}
			.trust-icon {
				width: 36px; height: 36px;
				display: flex;
				align-items: center;
				justify-content: center;
				color: var(--accent-light);
			}

			/* ── DISCOVER ── */
			.discover {
				position: relative;
				max-width: 1100px;
				margin: 0 auto;
				padding: 120px 56px;
			}
			/* Blueprint grid */
			.discover::before {
				content: '';
				position: absolute;
				inset: 0;
				background-image:
					linear-gradient(rgba(59,130,246,0.03) 1px, transparent 1px),
					linear-gradient(90deg, rgba(59,130,246,0.03) 1px, transparent 1px);
				background-size: 80px 80px;
				pointer-events: none;
			}

			.discover-header {
				text-align: center;
				margin-bottom: 64px;
				position: relative;
			}
			.discover-header h2 {
				font-size: clamp(28px, 4vw, 44px);
				font-weight: 800;
				color: var(--text);
				letter-spacing: -0.04em;
				margin-bottom: 14px;
			}
			.discover-header p {
				font-size: 16px;
				color: var(--text-sub);
			}

			.cards-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 16px;
				position: relative;
			}
			.cards-row-2 {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 16px;
				margin-top: 16px;
				max-width: calc(66.66% + 5px);
				position: relative;
			}

			.card {
				position: relative;
				padding: 32px 28px;
				background: var(--bg-card);
				border: 1px solid var(--border);
				border-radius: 14px;
				backdrop-filter: blur(8px);
				-webkit-backdrop-filter: blur(8px);
				overflow: hidden;
				transition: all 0.3s cubic-bezier(0.16,1,0.3,1);
			}
			.card:hover {
				border-color: var(--accent-border);
				background: rgba(59,130,246,0.07);
				transform: translateY(-3px);
				box-shadow: 0 8px 32px rgba(0,0,0,0.3);
			}

			.card-num {
				position: absolute;
				top: 12px; right: 20px;
				font-size: 64px;
				font-weight: 900;
				color: rgba(59,130,246,0.06);
				line-height: 1;
				pointer-events: none;
				letter-spacing: -0.04em;
			}

			.card-icon {
				width: 42px; height: 42px;
				display: flex;
				align-items: center;
				justify-content: center;
				background: var(--accent-soft);
				border: 1px solid var(--accent-border);
				border-radius: 10px;
				color: var(--accent-light);
				margin-bottom: 20px;
			}

			.card h3 {
				font-size: 17px;
				font-weight: 700;
				color: var(--text);
				margin-bottom: 8px;
				letter-spacing: -0.02em;
				line-height: 1.35;
			}
			.card p {
				font-size: 14px;
				color: var(--text-sub);
				line-height: 1.65;
			}

			/* ── CTA SECTION ── */
			.cta {
				background: var(--bg-elevated);
				border-top: 1px solid var(--border);
				padding: 100px 56px;
				text-align: center;
				position: relative;
				overflow: hidden;
			}
			.cta::before {
				content: '';
				position: absolute;
				top: 0; left: 0; right: 0;
				height: 2px;
				background: linear-gradient(90deg, transparent, var(--accent), var(--cyan), var(--accent), transparent);
			}
			/* Blueprint grid */
			.cta::after {
				content: '';
				position: absolute;
				inset: 0;
				background-image:
					linear-gradient(rgba(59,130,246,0.03) 1px, transparent 1px),
					linear-gradient(90deg, rgba(59,130,246,0.03) 1px, transparent 1px);
				background-size: 80px 80px;
				pointer-events: none;
			}

			.cta-inner { position: relative; z-index: 1; }

			.cta-icon {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				width: 56px; height: 56px;
				margin-bottom: 28px;
				color: var(--accent-light);
			}

			.cta h2 {
				font-size: clamp(26px, 3.5vw, 38px);
				font-weight: 800;
				color: var(--text);
				margin-bottom: 14px;
				letter-spacing: -0.03em;
			}
			.cta-sub {
				font-size: 16px;
				color: var(--text-sub);
				margin-bottom: 40px;
				max-width: 480px;
				margin-left: auto;
				margin-right: auto;
				line-height: 1.6;
			}

			.cta-form {
				display: flex;
				flex-direction: column;
				gap: 14px;
				max-width: 460px;
				margin: 0 auto 20px;
			}
			.cta-form input {
				width: 100%;
				padding: 16px 20px;
				background: rgba(59,130,246,0.04);
				border: 1px solid var(--border);
				border-radius: 10px;
				font-family: var(--font);
				font-size: 15px;
				color: var(--text);
				outline: none;
				transition: all 0.2s;
			}
			.cta-form input::placeholder { color: var(--text-muted); }
			.cta-form input:focus {
				border-color: var(--accent);
				box-shadow: 0 0 0 3px rgba(59,130,246,0.08);
			}

			.cta-form .btn-primary {
				width: 100%;
				justify-content: center;
				padding: 18px;
				font-size: 16px;
			}

			.cta-micro {
				font-size: 13px;
				color: var(--text-muted);
			}

			.form-ok {
				display: none;
				max-width: 460px;
				margin: 0 auto;
				padding: 24px;
				background: rgba(34,211,238,0.06);
				border: 1px solid var(--cyan-glow);
				border-radius: 10px;
				color: var(--cyan);
				font-size: 15px;
				font-weight: 500;
			}

			/* ── FOOTER ── */
			.footer {
				padding: 24px 56px;
				text-align: center;
				font-size: 13px;
				color: var(--text-muted);
				border-top: 1px solid var(--border);
			}
			.footer a { color: var(--text-muted); text-decoration: none; }
			.footer a:hover { color: var(--text-sub); }

			/* ── RESPONSIVE ── */
			@media (max-width: 768px) {
				.hero { padding: 40px 24px 60px; min-height: 90vh; }
				.hero h1 { font-size: 34px; }
				.hero-sub { font-size: 16px; }

				.trust { padding: 24px; }
				.trust-row { gap: 20px; flex-direction: column; }

				.discover { padding: 60px 24px; }
				.cards-grid { grid-template-columns: 1fr; }
				.cards-row-2 { grid-template-columns: 1fr; max-width: 100%; }

				.cta { padding: 60px 24px 80px; }
			}
		</style>
	</head>

	<body>
		<!-- HERO -->
		<section class="hero">
			<div class="hero-bg"></div>
			<div class="hero-content">
				<span class="hero-badge ha">GUIDE GRATUIT · ÉDITION 2026</span>
				<h1 class="ha">Les 5 angles morts qui coûtent des millions à vos <span class="h1-accent">événements MICE</span> en 2026</h1>
				<p class="hero-sub ha">Une analyse des failles structurelles qui fragmentent la gouvernance M&E. Et les leviers pour y remédier.</p>
				<a href="#cta-form" class="btn-primary ha">Télécharger le livre blanc <span>&rarr;</span></a>
			</div>
		</section>

		<!-- TRUST BAR -->
		<section class="trust">
			<div class="trust-row">
				<div class="trust-item rv">
					<div class="trust-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div>
					<span>+20 ans d'expertise MICE</span>
				</div>
				<div class="trust-item rv">
					<div class="trust-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg></div>
					<span>Étude basée sur des données terrain 2025-2026</span>
				</div>
				<div class="trust-item rv">
					<div class="trust-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg></div>
					<span>Méthodologie validée par des experts du secteur</span>
				</div>
			</div>
		</section>

		<!-- CE QUE VOUS DÉCOUVRIREZ -->
		<section class="discover">
			<div class="discover-header">
				<h2 class="rv">Ce que vous découvrirez</h2>
				<p class="rv">Un condensé actionnable pour structurer la gouvernance de vos événements MICE.</p>
			</div>

			<div class="cards-grid">
				<div class="card rv">
					<span class="card-num">01</span>
					<div class="card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div>
					<h3>Le MICE n'appartient à personne</h3>
					<p>Travel, achats, finance, com, RH : tout le monde touche au sujet, personne ne le structure.</p>
				</div>
				<div class="card rv">
					<span class="card-num">02</span>
					<div class="card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
					<h3>Structurer sans légitimité est politiquement risqué</h3>
					<p>Cadrer les meetings, c'est toucher à l'autonomie des équipes et à la culture interne.</p>
				</div>
				<div class="card rv">
					<span class="card-num">03</span>
					<div class="card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><circle cx="6" cy="6" r="1"/><circle cx="6" cy="18" r="1"/></svg></div>
					<h3>Vos outils ne communiquent pas entre eux</h3>
					<p>ERP, T&E, event tech, agences : 4 sphères qui se chevauchent sans converger.</p>
				</div>
			</div>
			<div class="cards-row-2">
				<div class="card rv">
					<span class="card-num">04</span>
					<div class="card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2a4 4 0 0 0-4 4c0 2 2 3 2 6h4c0-3 2-4 2-6a4 4 0 0 0-4-4z"/><line x1="10" y1="16" x2="14" y2="16"/><line x1="10" y1="19" x2="14" y2="19"/><line x1="11" y1="22" x2="13" y2="22"/></svg></div>
					<h3>L'IA est partout. La gouvernance nulle part.</h3>
					<p>Classification auto, RFP, consolidation : l'IA avance, mais sans cadre, elle amplifie le chaos.</p>
				</div>
				<div class="card rv">
					<span class="card-num">05</span>
					<div class="card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="m16 12-4-4-4 4"/><path d="M12 16V8"/></svg></div>
					<h3>Le marché attend un standard. Pas un outil de plus.</h3>
					<p>La différenciation ne se fait plus par les features mais par la capacité à définir le cadre.</p>
				</div>
			</div>
		</section>

		<!-- CTA -->
		<section class="cta">
			<div class="cta-inner">
				<div class="cta-icon"><svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg></div>
				<h2 class="rv">Recevez votre livre blanc</h2>
				<p class="cta-sub rv">30 pages d'analyses, de cas concrets et de recommandations pour structurer votre gouvernance M&E en 2026.</p>
				<form class="cta-form rv" data-form="onemice-lead" action="#" id="cta-form">
					<input type="text" name="prenom" placeholder="Votre prénom" required />
					<input type="email" name="email" placeholder="Votre email professionnel" required />
					<input type="text" name="entreprise" placeholder="Votre entreprise (optionnel)" />
					<button type="submit" class="btn-primary">Télécharger gratuitement <span>&rarr;</span></button>
				</form>
				<div class="form-ok" id="cta-ok">Merci ! Vous recevrez le livre blanc dans les prochaines minutes.</div>
				</div>
		</section>

		<!-- FOOTER -->
		<footer class="footer">
			<p>© 2026 OneMice · <a href="#">Politique de confidentialité</a></p>
		</footer>

		<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
		<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
		<script>
			gsap.registerPlugin(ScrollTrigger);
			gsap.from('.ha', { opacity:0, y:32, duration:0.9, stagger:0.15, ease:'power2.out', delay:0.3 });
			document.querySelectorAll('.rv').forEach(el => {
				gsap.from(el, {
					scrollTrigger: { trigger:el, start:'top 92%', toggleActions:'play none none none' },
					opacity:0, y:24, duration:0.7,
					delay: el.closest('.cards-grid,.cards-row-2') ? [...el.parentElement.children].indexOf(el)*0.1 : 0,
					ease:'power2.out'
				});
			});
			const f=document.getElementById('cta-form'),s=document.getElementById('cta-ok');
			f.addEventListener('submit',e=>{
				e.preventDefault();
				const b=f.querySelector('button');b.textContent='Envoi...';b.disabled=true;
				setTimeout(()=>{
					gsap.to(f,{opacity:0,y:-8,duration:0.25,onComplete:()=>{
						f.style.display='none';s.style.display='block';
						gsap.from(s,{opacity:0,y:8,duration:0.3});
					}});
				},500);
			});
		</script>
	</body>
</html>
