<html lang="fr">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Clinitex x Kokoro — Programme COPIL IA · 25 mars 2026</title>
		<meta name="description" content="Programme de formation IA pour le COPIL Clinitex — 25 mars 2026" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
		<script src="https://unpkg.com/lucide@0.460.0/dist/umd/lucide.min.js" defer></script>
		<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js" defer></script>
		<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js" defer></script>
	</head>
	<body>

		<!-- ==================== SLIDE 0 — COVER ==================== -->
		<section class="hero" id="hero">
			<div class="hero-glow"></div>
			<div class="container">
				<div class="cover-logos">
					<span class="cover-logo">Clinitex</span>
					<span class="cover-x">&times;</span>
					<span class="cover-logo">Kokoro</span>
				</div>
				<p class="hero-eyebrow">Programme COPIL IA</p>
				<h1>Rendre le monde plus beau.<br/>L'IA, votre nouveau <span class="gradient-text">super-pouvoir</span>.</h1>
				<div class="cover-meta">
					<span><i data-lucide="calendar" style="width:14px;height:14px;vertical-align:-2px;margin-right:4px;"></i> 25 mars 2026</span>
					<span><i data-lucide="clock" style="width:14px;height:14px;vertical-align:-2px;margin-right:4px;"></i> 9h &ndash; 17h</span>
					<span><i data-lucide="map-pin" style="width:14px;height:14px;vertical-align:-2px;margin-right:4px;"></i> Villeneuve d'Ascq</span>
					<span><i data-lucide="users" style="width:14px;height:14px;vertical-align:-2px;margin-right:4px;"></i> 17 participants</span>
				</div>
			</div>
		</section>

		<!-- ==================== SLIDE 1 — AGENDA DU CALL ==================== -->
		<section class="section" id="agenda">
			<div class="container">
				<p class="section-label reveal">Agenda du call</p>
				<h2 class="reveal">3 points à couvrir ensemble</h2>
				<div class="cards-grid cards-3 reveal-group">
					<div class="card reveal">
						<div class="card-num">01</div>
						<div class="card-icon"><i data-lucide="settings"></i></div>
						<h3>Vérifier le setup général</h3>
						<p>S'assurer que tout est prêt côté admin Claude pour ne perdre aucune minute le 25.</p>
					</div>
					<div class="card reveal">
						<div class="card-num">02</div>
						<div class="card-icon"><i data-lucide="route"></i></div>
						<h3>Le plan de la journée</h3>
						<p>Présenter le déroulé, les cas d'usage, la logique. Valider ensemble.</p>
					</div>
					<div class="card reveal">
						<div class="card-num">03</div>
						<div class="card-icon"><i data-lucide="message-circle-question"></i></div>
						<h3>Questions & feedback</h3>
						<p>Vos retours, ajustements, éléments manquants, logistique.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- ==================== SLIDE 2 — VÉRIFIER LES CONNEXIONS ==================== -->
		<section class="section" id="connexions">
			<div class="container">
				<p class="section-label reveal">Étape 1</p>
				<h2 class="reveal">Vérifier le setup général</h2>
				<p class="section-sub reveal">Tout doit être opérationnel avant le 25. Zéro temps perdu en paramétrage le jour J.</p>
				<div class="check-grid reveal-group">
					<div class="check-item reveal">
						<div class="check-icon"><i data-lucide="users"></i></div>
						<div>
							<h3>Comptes Claude Cowork</h3>
							<p>Les 17 participants ont tous accès ? Identifiants créés et testés ?</p>
						</div>
					</div>
					<div class="check-item reveal">
						<div class="check-icon"><i data-lucide="mail"></i></div>
						<div>
							<h3>Connecteur Microsoft</h3>
							<p>Outlook + Calendar connectés dans les paramètres admin du workspace.</p>
						</div>
					</div>
					<div class="check-item reveal">
						<div class="check-icon"><i data-lucide="link"></i></div>
						<div>
							<h3>Connecteurs</h3>
							<p>Notion, Microsoft, autres intégrations — est-ce activé côté admin ?</p>
						</div>
					</div>
					<div class="check-item reveal">
						<div class="check-icon"><i data-lucide="smartphone"></i></div>
						<div>
							<h3>App mobile</h3>
							<p>Les DA peuvent installer l'app sur leur téléphone pro ? Contraintes MDM ?</p>
						</div>
					</div>
						<div class="check-item reveal">
						<div class="check-icon"><i data-lucide="projector"></i></div>
						<div>
							<h3>Salle & équipement</h3>
							<p>Configuration en U, vidéoprojecteur, adaptateur HDMI/USB-C.</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- ==================== SLIDE 3 — LE CONCEPT ==================== -->
		<section class="section" id="concept">
			<div class="why-claude-bg-glow"></div>
			<div class="container" style="position:relative;z-index:1;">
				<p class="section-label reveal">Étape 2 — Le plan</p>
				<h2 class="reveal">Le concept de la journée</h2>
				<p class="section-sub reveal">Rendre le monde plus beau, ça passe par <strong>3 relations essentielles</strong>. Vous êtes les héros de ces relations. L'IA est un de vos super-pouvoirs.</p>
				<div class="cards-grid cards-3 reveal-group">
					<div class="card card--featured reveal">
						<div class="card-num">01</div>
						<div class="card-icon"><i data-lucide="heart-handshake"></i></div>
						<h3>Belle relation client</h3>
						<p>Le client est signé. Comment on le garde, on l'enchante, on anticipe ses besoins.</p>
					</div>
					<div class="card card--featured reveal">
						<div class="card-num">02</div>
						<div class="card-icon"><i data-lucide="target"></i></div>
						<h3>Belle relation prospect</h3>
						<p>Le prospect n'a pas signé. Comment on le comprend, on lui parle, on convertit.</p>
					</div>
					<div class="card card--featured reveal">
						<div class="card-num">03</div>
						<div class="card-icon"><i data-lucide="user-check"></i></div>
						<h3>Belle relation collaborateur</h3>
						<p>L'agent est sur le terrain. Comment on l'accompagne, on le valorise.</p>
					</div>
				</div>
							</div>
		</section>

		<!-- ==================== SLIDE 4 — TIMELINE ==================== -->
		<section class="section" id="timeline">
			<div class="container">
				<p class="section-label reveal">Déroulé</p>
				<h2 class="reveal">La journée, heure par heure</h2>
				<div class="program-timeline">
					<div class="program-step">
						<div class="program-dot"></div>
						<div class="program-step-card">
							<div class="program-time">9h00</div>
							<h3>Ouverture</h3>
							<p>Tour de table : usages actuels, attentes, peurs. Présentation du fil conducteur.</p>
						</div>
					</div>
					<div class="program-step">
						<div class="program-dot"></div>
						<div class="program-step-card">
							<div class="program-time">9h15</div>
							<h3>Setup & paramétrage</h3>
							<p>Connexion Claude, app mobile, connecteurs, paramètres généraux. Premier test.</p>
							<div class="program-badges">
								<span class="badge">Chat</span>
								<span class="badge">Mobile</span>
							</div>
						</div>
					</div>
					<div class="program-step">
						<div class="program-dot"></div>
						<div class="program-step-card">
							<div class="program-time">9h45</div>
							<h3>Apprendre à prompter</h3>
							<p>5 règles d'or. Exercice live : chaque DA formule un vrai problème en prompt.</p>
							<div class="program-badges">
								<span class="badge">Chat</span>
							</div>
						</div>
					</div>
					<div class="program-step">
						<div class="program-dot program-dot--accent"></div>
						<div class="program-step-card program-step-card--accent">
							<div class="program-time">10h25</div>
							<h3>Acte 1 — Belle relation client</h3>
							<p>Mails & urgences → Contrôle qualité → Anticipation tendances → Appels proactifs</p>
							<div class="program-badges">
								<span class="badge">Chat</span>
								<span class="badge">Artifacts</span>
								<span class="badge">Cowork</span>
								<span class="badge">Mobile</span>
							</div>
						</div>
					</div>
					<div class="program-step">
						<div class="program-dot program-dot--muted"></div>
						<div class="program-step-card">
							<div class="program-time">12h30</div>
							<h3>Déjeuner</h3>
							<p></p>
						</div>
					</div>
					<div class="program-step">
						<div class="program-dot program-dot--accent"></div>
						<div class="program-step-card program-step-card--accent">
							<div class="program-time">14h00</div>
							<h3>Acte 2 — Belle relation prospect</h3>
							<p>Préparation RDV → Offre commerciale → Relances commerciales → Veille territoriale</p>
							<div class="program-badges">
								<span class="badge">Chat</span>
								<span class="badge">Artifacts</span>
								<span class="badge">Web</span>
								<span class="badge">Excel</span>
								<span class="badge">PowerPoint</span>
								<span class="badge">Skills</span>
							</div>
						</div>
					</div>
					<div class="program-step">
						<div class="program-dot program-dot--green"></div>
						<div class="program-step-card program-step-card--green">
							<div class="program-time">15h35</div>
							<h3>Acte 3 — Belle relation collaborateur</h3>
							<p>Entretien professionnel → Gazette d'agence → Veille territoriale</p>
							<div class="program-badges">
								<span class="badge">Chat</span>
								<span class="badge">Artifacts</span>
								<span class="badge">Skills</span>
								<span class="badge badge--green">Schedule</span>
							</div>
						</div>
					</div>
					<div class="program-step">
						<div class="program-dot"></div>
						<div class="program-step-card">
							<div class="program-time">16h35</div>
							<h3>Closing</h3>
							<p>Exploration libre → Feuille de route perso (3 actions) → Q&A</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- ==================== SLIDE 5 — ACTE 1 ==================== -->
		<section class="section" id="acte1">
			<div class="container">
				<p class="section-label reveal">Acte 1</p>
				<h2 class="reveal">Belle relation <span class="gradient-text">client</span></h2>
				<p class="section-sub reveal">Le client est signé. Comment on le garde.</p>
				<div class="acte-list">
					<div class="acte-item reveal">
						<div class="acte-icon"><i data-lucide="mail-open"></i></div>
						<div>
							<h3>"J'ouvre mes mails lundi matin"</h3>
							<p>Résumer 10 mails, identifier les urgences, drafter 3 réponses. Chaque DA sur ses vrais mails.</p>
						</div>
					</div>
					<div class="acte-item reveal">
						<div class="acte-icon"><i data-lucide="clipboard-check"></i></div>
						<div>
							<h3>"Je fais un contrôle qualité sur site"</h3>
							<p>Analyser 1 CQ de son agence → note, alertes, plan d'action, mail client. Sur les vrais CQ 2026.</p>
						</div>
					</div>
					<div class="acte-item reveal">
						<div class="acte-icon"><i data-lucide="trending-up"></i></div>
						<div>
							<h3>"Je veux anticiper les problèmes"</h3>
							<p>3 CQ du même site → détecter la tendance, préparer la revue qualité. Dashboard Artifacts.</p>
						</div>
					</div>
					<div class="acte-item reveal">
						<div class="acte-icon"><i data-lucide="phone-call"></i></div>
						<div>
							<h3>"Je dois appeler mes clients"</h3>
							<p>Claude prépare le brief avant chaque appel en mode conversation guidée. Historique + points d'attention.</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- ==================== SLIDE 6 — ACTE 2 ==================== -->
		<section class="section" id="acte2">
			<div class="container">
				<p class="section-label reveal">Acte 2</p>
				<h2 class="reveal">Belle relation <span class="gradient-text">prospect</span></h2>
				<p class="section-sub reveal">Le prospect n'a pas signé. Comment on convertit.</p>
				<div class="acte-list">
					<div class="acte-item reveal">
						<div class="acte-icon"><i data-lucide="search"></i></div>
						<div>
							<h3>"Je prépare mon rendez-vous"</h3>
							<p>Veille sur le prospect : secteur, enjeux, concurrents. Chaque DA sur un vrai prospect de sa zone.</p>
						</div>
					</div>
					<div class="acte-item reveal">
						<div class="acte-icon"><i data-lucide="file-text"></i></div>
						<div>
							<h3>"Je fais l'offre commerciale"</h3>
							<p>Brief → page "Vos besoins" avec les verbatims du prospect → intégration dans le template PPT Clinitex.</p>
						</div>
					</div>
					<div class="acte-item reveal">
						<div class="acte-icon"><i data-lucide="refresh-cw"></i></div>
						<div>
							<h3>"Je relance mes anciens prospects"</h3>
							<p>Ouvrir les relances M7 de sa zone → Claude priorise → script d'appel personnalisé. Excel live.</p>
						</div>
					</div>
					<div class="acte-item reveal">
						<div class="acte-icon"><i data-lucide="globe"></i></div>
						<div>
							<h3>"Je surveille mon territoire"</h3>
							<p>Veille territoriale sur sa zone géo. On crée ensemble un Skill réutilisable.</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- ==================== SLIDE 7 — ACTE 3 ==================== -->
		<section class="section" id="acte3">
			<div class="container">
				<p class="section-label reveal">Acte 3</p>
				<h2 class="reveal">Belle relation <span class="gradient-text">collaborateur</span></h2>
				<p class="section-sub reveal">L'agent est sur le terrain. Comment on le valorise.</p>
				<div class="acte-list">
					<div class="acte-item reveal">
						<div class="acte-icon"><i data-lucide="handshake"></i></div>
						<div>
							<h3>"J'ai un entretien pro avec un agent"</h3>
							<p>Synthèse année, points forts, objectifs, CR structuré. Être dans l'échange, pas dans la prise de notes.</p>
						</div>
					</div>
					<div class="acte-item reveal">
						<div class="acte-icon"><i data-lucide="newspaper"></i></div>
						<div>
							<h3>"Je dois faire la gazette de mon agence"</h3>
							<p>Bullet points → gazette complète au format Clinitex. On crée un Skill + Schedule mensuel.</p>
						</div>
					</div>
					<div class="acte-item reveal">
						<div class="acte-icon"><i data-lucide="radar"></i></div>
						<div>
							<h3>"Je veux surveiller mon territoire"</h3>
							<p>Veille éco territoriale : entreprises en croissance, appels d'offres, actus marché local.</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- ==================== SLIDE 8 — PROCHAINES ÉTAPES ==================== -->
		<section class="section" id="next">
			<div class="why-claude-bg-glow"></div>
			<div class="container" style="position:relative;z-index:1;">
				<p class="section-label reveal">Étape 3</p>
				<h2 class="reveal">Prochaines étapes</h2>
				<div class="next-grid reveal-group">
					<div class="next-card next-card--highlight reveal">
						<h3><i data-lucide="building" style="width:16px;height:16px;vertical-align:-2px;margin-right:6px;color:#4D9DE0;"></i> Avant le 25 — Côté Clinitex</h3>
						<ul>
							<li>Valider les accès Claude Cowork pour les 17</li>
							<li>Activer connecteurs Microsoft + Notion (admin)</li>
							<li>Confirmer politique app mobile</li>
							<li>Envoyer un verbatim / CR d'appel client (si dispo)</li>
							<li>Confirmer salle en U + équipement</li>
						</ul>
					</div>
					<div class="next-card next-card--highlight reveal">
						<h3><i data-lucide="rocket" style="width:16px;height:16px;vertical-align:-2px;margin-right:6px;color:#4D9DE0;"></i> Avant le 25 — Côté Kokoro</h3>
						<ul>
							<li>Envoyer la feuille de route aux 17 participants</li>
							<li>Préparer les prompts prêts à l'emploi par cas d'usage</li>
							<li>Préparer les démos sur données réelles Clinitex</li>
							<li>Construire les Skills (Gazette + Veille)</li>
							<li>Envoyer la facture</li>
						</ul>
					</div>
					<div class="next-card reveal">
						<h3><i data-lucide="package" style="width:16px;height:16px;vertical-align:-2px;margin-right:6px;color:hsla(0,0%,100%,.4);"></i> Le 25 — Livrables</h3>
						<ul>
							<li>Claude configuré + app mobile installée</li>
							<li>Cheat sheet prompting DA</li>
							<li>Skill "Gazette" prêt à l'emploi</li>
							<li>Skill "Veille territoriale"</li>
							<li>Feuille de route perso (3 actions)</li>
						</ul>
					</div>
					<div class="next-card reveal">
						<h3><i data-lucide="help-circle" style="width:16px;height:16px;vertical-align:-2px;margin-right:6px;color:hsla(0,0%,100%,.4);"></i> Questions ouvertes</h3>
						<ul>
							<li>Les 3 axes couvrent vos priorités ?</li>
							<li>Un cas d'usage manquant ?</li>
							<li>Retours, ajustements ?</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- ==================== SLIDE 9 — CLOSING ==================== -->
		<section class="section closing" id="closing">
			<div class="final-glow"></div>
			<div class="container" style="position:relative;z-index:1;">
				<h2 class="reveal">Rendre le monde plus beau,<br/>ça commence par avoir le <span class="gradient-text">temps</span> de le faire.</h2>
				<p class="closing-meta reveal">Clinitex &times; Kokoro &middot; 25 mars 2026</p>
			</div>
		</section>

		<!-- JS -->
		<script>
			document.addEventListener('DOMContentLoaded', () => {
				if (window.lucide) lucide.createIcons();

				if (window.gsap && window.ScrollTrigger) {
					gsap.registerPlugin(ScrollTrigger);

					// Reveal elements with stagger per section
					document.querySelectorAll('section').forEach(section => {
						const els = section.querySelectorAll('.reveal');
						if (els.length) {
							gsap.fromTo(els,
								{ opacity: 0, y: 30, filter: 'blur(4px)' },
								{
									opacity: 1, y: 0, filter: 'blur(0px)',
									duration: 0.8,
									stagger: 0.12,
									ease: 'power3.out',
									scrollTrigger: { trigger: section, start: 'top 80%', once: true }
								}
							);
						}
					});

					// Hero entrance
					gsap.fromTo('.cover-logos',
						{ opacity: 0, y: 20 },
						{ opacity: 1, y: 0, duration: 0.7, delay: 0.2, ease: 'power3.out' }
					);
					gsap.fromTo('.hero-eyebrow',
						{ opacity: 0, y: 20 },
						{ opacity: 1, y: 0, duration: 0.7, delay: 0.35, ease: 'power3.out' }
					);
					gsap.fromTo('.hero h1',
						{ opacity: 0, y: 30 },
						{ opacity: 1, y: 0, duration: 0.8, delay: 0.5, ease: 'power3.out' }
					);
					gsap.fromTo('.cover-meta',
						{ opacity: 0, y: 20 },
						{ opacity: 1, y: 0, duration: 0.7, delay: 0.7, ease: 'power3.out' }
					);

					// Program timeline dots
					gsap.fromTo('.program-dot',
						{ opacity: 0, scale: 0 },
						{
							opacity: 1, scale: 1, duration: 0.4, stagger: 0.12, ease: 'back.out(2)',
							scrollTrigger: { trigger: '.program-timeline', start: 'top 80%', once: true }
						}
					);

					// Program timeline cards alternate from left/right
					document.querySelectorAll('.program-step').forEach((step, i) => {
						const card = step.querySelector('.program-step-card');
						const fromX = i % 2 === 0 ? -40 : 40;
						gsap.fromTo(card,
							{ opacity: 0, x: fromX },
							{
								opacity: 1, x: 0, duration: 0.6, ease: 'power3.out',
								scrollTrigger: { trigger: step, start: 'top 85%', once: true }
							}
						);
					});
				}
			});
		</script>
	</body>
</html>

<style>
	/* ===== RESET & BASE ===== */
	* { margin: 0; padding: 0; box-sizing: border-box; }
	html { scroll-behavior: smooth; }

	body {
		font-family: 'Inter', -apple-system, system-ui, sans-serif;
		background: #0A0812;
		color: hsla(0,0%,100%,.6);
		line-height: 1.7;
		-webkit-font-smoothing: antialiased;
	}

	.container {
		max-width: 1000px;
		margin: 0 auto;
		padding: 0 28px;
	}

	.reveal { opacity: 0; }

	/* ===== TYPOGRAPHY ===== */
	h1, h2 {
		font-family: 'Inter', -apple-system, system-ui, sans-serif;
		font-weight: 800;
		letter-spacing: -0.04em;
	}

	h3 {
		font-family: 'Inter', -apple-system, system-ui, sans-serif;
		font-weight: 700;
		letter-spacing: -0.01em;
	}

	.gradient-text {
		background: linear-gradient(135deg, #4D9DE0, #0055A4, #7EC8E3);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
