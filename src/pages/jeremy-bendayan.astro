---

<html lang="fr">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Jeremy × Kokoro — Construire la première agence IA française</title>
		<meta name="description" content="Pitch advisor Kokoro — Samuel & Simon. Final stage Anthropic. 18 mois pour le top 20. 3 ans pour le top 100." />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
		<script src="https://unpkg.com/lucide@0.460.0/dist/umd/lucide.min.js" defer></script>
		<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js" defer></script>
		<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js" defer></script>
	</head>
	<body>

		<!-- ==================== HERO ==================== -->
		<section class="hero" id="hero">
			<div class="hero-glow"></div>
			<div class="container">
				<div class="cover-logos">
					<span class="cover-logo">Jeremy</span>
					<span class="cover-x">&times;</span>
					<span class="cover-logo">Kokoro</span>
				</div>
				<p class="hero-eyebrow">Pitch advisor — Avril 2026</p>
				<h1>On veut construire la première<br/>agence IA française.<br/><span class="gradient-text">On a besoin de toi.</span></h1>
				<p class="hero-sub">Final stage Anthropic. Deux fondateurs. Une fenêtre de 18 mois.</p>
				<a class="cta-primary" href="#moment">
					<span>Lire le pitch</span>
					<i data-lucide="arrow-down" style="width:16px;height:16px;"></i>
				</a>
			</div>
		</section>

		<!-- ==================== LOGOS STRIP ==================== -->
		<section class="logos-strip">
			<div class="container">
				<p class="logos-label">Ils nous font confiance</p>
				<div class="logos-track">
					<div class="logos-row">
						<img src="/logos/spendesk.png" alt="Spendesk" />
						<img src="/logos/dynabuy.svg" alt="Dynabuy" />
						<img src="/logos/assemble.svg" alt="Assemble" />
						<img src="/logos/pilliot.svg" alt="Pilliot" />
						<img src="/logos/pleyce.svg" alt="Pleyce" />
						<img src="/logos/affective.svg" alt="Affective" />
						<img src="/logos/spendesk.png" alt="Spendesk" />
						<img src="/logos/dynabuy.svg" alt="Dynabuy" />
						<img src="/logos/assemble.svg" alt="Assemble" />
						<img src="/logos/pilliot.svg" alt="Pilliot" />
						<img src="/logos/pleyce.svg" alt="Pleyce" />
						<img src="/logos/affective.svg" alt="Affective" />
					</div>
				</div>
			</div>
		</section>

		<!-- ==================== STATS ==================== -->
		<section class="section section--tight" id="stats">
			<div class="container">
				<div class="stats-grid reveal-group">
					<div class="stat reveal">
						<div class="stat-num">244 K€</div>
						<div class="stat-label">CA cumulé en 2 ans</div>
					</div>
					<div class="stat reveal">
						<div class="stat-num">40<span class="stat-plus">+</span></div>
						<div class="stat-label">Clients B2B</div>
					</div>
					<div class="stat reveal">
						<div class="stat-num">4</div>
						<div class="stat-label">Offres structurées</div>
					</div>
					<div class="stat reveal">
						<div class="stat-num">#1</div>
						<div class="stat-label">Vague Anthropic FR</div>
					</div>
				</div>
			</div>
		</section>

		<!-- ==================== LE MOMENT ==================== -->
		<section class="section" id="moment">
			<div class="why-claude-bg-glow"></div>
			<div class="container" style="position:relative;z-index:1;">
				<p class="section-label reveal">Le moment</p>
				<h2 class="reveal">C'est <span class="gradient-text">maintenant</span>.</h2>
				<p class="section-sub reveal">Anthropic structure son réseau de partenaires intégrateurs en France. <strong>On sera parmi les premiers validés.</strong> Le statut de primo-entrant ouvre une fenêtre courte pour scaler un modèle d'agence avant que le marché ne se referme.</p>
				<div class="cards-grid cards-3 reveal-group">
					<div class="card reveal">
						<div class="card-num">01</div>
						<div class="card-icon"><i data-lucide="medal"></i></div>
						<h3>Primo-entrants</h3>
						<p>Un cercle restreint de partenaires intégrateurs en France. On en fera partie une fois validés.</p>
					</div>
					<div class="card reveal">
						<div class="card-num">02</div>
						<div class="card-icon"><i data-lucide="zap"></i></div>
						<h3>Modèle agence scalable</h3>
						<p>L'IA permet enfin de faire de la marge à l'échelle. La fenêtre est ouverte 18 mois.</p>
					</div>
					<div class="card reveal">
						<div class="card-num">03</div>
						<div class="card-icon"><i data-lucide="alarm-clock"></i></div>
						<h3>Une fenêtre qui se referme</h3>
						<p>Dans 18 mois, ce sont les Big 4 et les ESN qui auront pris la place. Elle se gagne aujourd'hui.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- ==================== POURQUOI TOI ==================== -->
		<section class="section" id="toi">
			<div class="container">
				<p class="section-label reveal">Pourquoi toi</p>
				<h2 class="reveal">Tu coches les <span class="gradient-text">4 cases</span><br/>qu'il nous faut.</h2>
				<div class="cards-grid cards-2 reveal-group">
					<div class="card card--featured reveal">
						<div class="card-num">01 — Conseil</div>
						<div class="card-icon"><i data-lucide="layout-grid"></i></div>
						<h3>Tu structures des practices qui scalent</h3>
						<p>Pricing, packaging, gouvernance, capacity planning. Le passage de 2 à 20 personnes, tu l'as déjà piloté.</p>
					</div>
					<div class="card card--featured reveal">
						<div class="card-num">02 — Agence</div>
						<div class="card-icon"><i data-lucide="briefcase"></i></div>
						<h3>Tu connais les vraies douleurs</h3>
						<p>Marge qui s'effrite, dépendance aux gros comptes, recrutement de seniors, transition associé. Tu l'as déjà vécu.</p>
					</div>
					<div class="card card--featured reveal">
						<div class="card-num">03 — Builder</div>
						<div class="card-icon"><i data-lucide="hammer"></i></div>
						<h3>Jaws Group + fish.vc</h3>
						<p>Tu opères en ce moment. Tes feedbacks sortent d'arbitrages que tu fais aujourd'hui, sur des sujets vivants.</p>
					</div>
					<div class="card card--featured reveal">
						<div class="card-num">04 — Réseau</div>
						<div class="card-icon"><i data-lucide="network"></i></div>
						<h3>Tu ouvres ce qu'on mettrait 2 ans à toquer</h3>
						<p>Clients grands comptes, talents seniors, écosystème conseil. Une intro de toi vaut six mois d'outbound.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- ==================== VISION ==================== -->
		<section class="section" id="vision">
			<div class="container">
				<p class="section-label reveal">La vision</p>
				<h2 class="reveal"><span class="gradient-text">20 ETP</span> en 18 mois.<br/><span class="gradient-text">100 ETP</span> en 3 ans.</h2>
				<div class="program-timeline">
					<div class="program-step">
						<div class="program-dot"></div>
						<div class="program-step-card">
							<div class="program-time">Aujourd'hui · Avril 2026</div>
							<h3>Deux fondateurs, une boîte rentable</h3>
							<p>244 K€ de CA cumulé, 40+ clients, quatre offres structurées. Partenariat Anthropic en validation.</p>
							<div class="program-badges">
								<span class="badge">2 fondateurs</span>
								<span class="badge">40+ clients</span>
							</div>
						</div>
					</div>
					<div class="program-step">
						<div class="program-dot program-dot--accent"></div>
						<div class="program-step-card program-step-card--accent">
							<div class="program-time">Horizon 18 mois</div>
							<h3>20 ETP — la core team</h3>
							<p>Une équipe senior structurée par practice. Machine commerciale rodée sur le mid-market. Premiers comptes enterprise signés. Le sceau Anthropic activé.</p>
							<div class="program-badges">
								<span class="badge">20 ETP</span>
								<span class="badge">Mid-market</span>
								<span class="badge">Anthropic in</span>
							</div>
						</div>
					</div>
					<div class="program-step">
						<div class="program-dot program-dot--accent"></div>
						<div class="program-step-card program-step-card--accent">
							<div class="program-time">Horizon 3 ans</div>
							<h3>100 ETP — l'échelle</h3>
							<p>Multi-practices : sales, marketing, ops, delivery. Comptes signature enterprise. Une organisation à la hauteur des grands cabinets, mais native IA.</p>
							<div class="program-badges">
								<span class="badge">100 ETP</span>
								<span class="badge">Multi-practices</span>
								<span class="badge">Enterprise</span>
							</div>
						</div>
					</div>
					<div class="program-step">
						<div class="program-dot program-dot--green"></div>
						<div class="program-step-card program-step-card--green">
							<div class="program-time">Horizon 4 ans</div>
							<h3>La référence française de l'IA en B2B</h3>
							<p>Marque qui pèse. École interne. Comptes signature européens. Le standard du marché pour l'intégration IA dans les équipes commerciales et marketing.</p>
							<div class="program-badges">
								<span class="badge badge--green">Référence FR</span>
								<span class="badge badge--green">École interne</span>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- ==================== CE QU'ON CHERCHE ==================== -->
		<section class="section" id="cherche">
			<div class="container">
				<p class="section-label reveal">Ce qu'on cherche</p>
				<h2 class="reveal">On a besoin de toi sur <span class="gradient-text">trois sujets</span>.</h2>
				<p class="section-sub reveal">On garde la main et on opère. On a besoin de ton <strong>expérience</strong> et de ton <strong>réseau</strong> pour aller plus vite et viser plus juste.</p>
				<div class="cards-grid cards-3 reveal-group">
					<div class="card card--featured reveal">
						<div class="card-num">01 — Pipeline</div>
						<div class="card-icon"><i data-lucide="target"></i></div>
						<h3>Nous ouvrir le mid-market et l'enterprise</h3>
						<p>Tu nous <strong>ouvres ton réseau</strong> pour les premières intros stratégiques. Tu nous challenges sur le packaging et le pricing à adapter pour ces tailles de comptes. Nous on signe.</p>
					</div>
					<div class="card card--featured reveal">
						<div class="card-num">02 — Recrutement</div>
						<div class="card-icon"><i data-lucide="user-plus"></i></div>
						<h3>Nous aider à recruter juste</h3>
						<p>Tu nous <strong>guides sur le sourcing, les scorecards, les packages</strong>, les profils qui marchent à ce stade. Tu interviens sur les 5 à 10 premiers seniors. Nous on porte le process.</p>
					</div>
					<div class="card card--featured reveal">
						<div class="card-num">03 — Process</div>
						<div class="card-icon"><i data-lucide="settings-2"></i></div>
						<h3>Nous aider à structurer pour passer à l'échelle</h3>
						<p>Tu nous <strong>partages les bons frameworks</strong> : gouvernance, capacity planning, delivery, rituels. Tu nous évites les pièges classiques du passage 2 → 20 → 100. Nous on construit.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- ==================== CTA FINAL ==================== -->
		<section class="section closing" id="closing">
			<div class="final-glow"></div>
			<div class="container" style="position:relative;z-index:1;">
				<p class="section-label reveal">On en parle ?</p>
				<h2 class="reveal">45 minutes.<br/>Pour <span class="gradient-text">faire le tour</span>.</h2>
				<p class="closing-sub reveal">Un premier échange : pitch détaillé, tes premières lectures, fit humain. Visio ou en physique, comme tu préfères.</p>
				<div class="cta-row reveal">
					<a class="cta-primary" href="https://calendly.com/samuel-kokoro-ai/appel-de-decouverte?month=2026-04" target="_blank" rel="noopener">
						<i data-lucide="calendar" style="width:16px;height:16px;"></i>
						<span>Bloquer un créneau</span>
					</a>
				</div>
				<p class="closing-meta reveal">Jeremy &times; Kokoro &middot; Pitch advisor &middot; Avril 2026</p>
			</div>
		</section>

		<!-- JS -->
		<script>
			document.addEventListener('DOMContentLoaded', () => {
				if (window.lucide) lucide.createIcons();

				if (window.gsap && window.ScrollTrigger) {
					gsap.registerPlugin(ScrollTrigger);

					document.querySelectorAll('section').forEach(section => {
						const els = section.querySelectorAll('.reveal');
						if (els.length) {
							gsap.fromTo(els,
								{ opacity: 0, y: 30, filter: 'blur(4px)' },
								{
									opacity: 1, y: 0, filter: 'blur(0px)',
									duration: 0.8,
									stagger: 0.1,
									ease: 'power3.out',
									scrollTrigger: { trigger: section, start: 'top 85%', once: true }
								}
							);
						}
					});

					gsap.fromTo('.cover-logos', { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.7, delay: 0.2, ease: 'power3.out' });
					gsap.fromTo('.hero-eyebrow', { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.7, delay: 0.35, ease: 'power3.out' });
					gsap.fromTo('.hero h1', { opacity: 0, y: 30 }, { opacity: 1, y: 0, duration: 0.8, delay: 0.5, ease: 'power3.out' });
					gsap.fromTo('.hero-sub', { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.7, delay: 0.65, ease: 'power3.out' });
					gsap.fromTo('.hero .cta-primary', { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.7, delay: 0.8, ease: 'power3.out' });

					gsap.fromTo('.program-dot', { opacity: 0, scale: 0 }, {
						opacity: 1, scale: 1, duration: 0.4, stagger: 0.12, ease: 'back.out(2)',
						scrollTrigger: { trigger: '.program-timeline', start: 'top 80%', once: true }
					});

					document.querySelectorAll('.program-step').forEach((step, i) => {
						const card = step.querySelector('.program-step-card');
						const fromX = i % 2 === 0 ? -40 : 40;
						gsap.fromTo(card, { opacity: 0, x: fromX }, {
							opacity: 1, x: 0, duration: 0.6, ease: 'power3.out',
							scrollTrigger: { trigger: step, start: 'top 85%', once: true }
						});
					});

					gsap.fromTo('.stat', { opacity: 0, y: 20 }, {
						opacity: 1, y: 0, duration: 0.7, stagger: 0.15, ease: 'power3.out',
						scrollTrigger: { trigger: '.stats-grid', start: 'top 85%', once: true }
					});
				}
			});
		</script>
	</body>
</html>

<style>
	/* ===== RESET & BASE ===== */
	* { margin: 0; padding: 0; box-sizing: border-box; }
	html { scroll-behavior: smooth; }

	body {
		font-family: 'Inter', -apple-system, system-ui, sans-serif;
		background: #0A0812;
		color: hsla(0,0%,100%,.6);
		line-height: 1.7;
		-webkit-font-smoothing: antialiased;
	}

	.container {
		max-width: 1000px;
		margin: 0 auto;
		padding: 0 28px;
	}

	.reveal { opacity: 0; }

	/* ===== TYPOGRAPHY ===== */
	h1, h2 {
		font-family: 'Inter', -apple-system, system-ui, sans-serif;
		font-weight: 800;
		letter-spacing: -0.04em;
	}

	h3 {
		font-family: 'Inter', -apple-system, system-ui, sans-serif;
		font-weight: 700;
		letter-spacing: -0.01em;
	}

	.gradient-text {
		background: linear-gradient(135deg, #60a5fa, #2563eb, #0f172a);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.section-label {
		font-size: 11px;
		text-transform: uppercase;
		letter-spacing: 5px;
		color: #2563eb;
		font-weight: 600;
		text-align: center;
		margin-bottom: 20px;
	}

	.section-sub {
		font-size: 17px;
		color: hsla(0,0%,100%,.55);
		max-width: 720px;
		margin: -32px auto 64px;
		text-align: center;
		line-height: 1.7;
	}

	.section-sub strong {
		color: hsla(0,0%,100%,.9);
		font-weight: 600;
	}

	/* ===== SECTIONS ===== */
	.section {
		padding: 130px 0;
		position: relative;
		overflow: hidden;
	}

	.section--tight {
		padding: 60px 0;
	}

	h2 {
		font-size: clamp(28px, 5vw, 48px);
		font-weight: 800;
		color: #fff;
		margin-bottom: 64px;
		text-align: center;
		line-height: 1.15;
	}

	/* ===== CTA ===== */
	.cta-primary {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		padding: 16px 28px;
		background: linear-gradient(135deg, #2563eb, #1d4ed8);
		border: 1px solid rgba(96, 165, 250, 0.3);
		border-radius: 12px;
		color: #fff;
		font-weight: 600;
		font-size: 14px;
		text-decoration: none;
		transition: all .3s cubic-bezier(.22,1,.36,1);
		box-shadow: 0 4px 24px rgba(37,99,235,0.3);
	}

	.cta-primary:hover {
		transform: translateY(-2px);
		box-shadow: 0 8px 32px rgba(37,99,235,0.5);
		border-color: rgba(96, 165, 250, 0.5);
	}

	.cta-row {
		display: flex;
		justify-content: center;
		margin: 32px 0 24px;
	}

	/* ===== HERO ===== */
	.hero {
		padding: 200px 0 140px;
		text-align: center;
		position: relative;
		overflow: hidden;
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.hero .container { position: relative; z-index: 1; }

	.hero-glow {
		position: absolute;
		top: -200px;
		left: 50%;
		transform: translateX(-50%);
		width: 1000px;
		height: 700px;
		background: radial-gradient(ellipse, rgba(37, 99, 235, 0.32) 0%, rgba(37, 99, 235, 0.12) 35%, rgba(15, 23, 42, 0.04) 60%, transparent 75%);
		pointer-events: none;
		animation: heroPulse 6s ease-in-out infinite;
	}

	@keyframes heroPulse {
		0%, 100% { opacity: 0.7; transform: translateX(-50%) scale(1); }
		50% { opacity: 1; transform: translateX(-50%) scale(1.08); }
	}

	.cover-logos {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 16px;
		margin-bottom: 24px;
		opacity: 0;
	}

	.cover-logo {
		font-size: 14px;
		font-weight: 800;
		letter-spacing: 4px;
		text-transform: uppercase;
		color: hsla(0,0%,100%,.9);
	}

	.cover-x {
		font-size: 16px;
		color: hsla(0,0%,100%,.25);
		font-weight: 500;
	}

	.hero-eyebrow {
		font-size: 13px;
		text-transform: uppercase;
		letter-spacing: 5px;
		color: #2563eb;
		font-weight: 700;
		margin-bottom: 28px;
		opacity: 0;
	}

	.hero h1 {
		font-size: clamp(34px, 5.5vw, 64px);
		font-weight: 800;
		line-height: 1.1;
		color: #fff;
		margin-bottom: 32px;
		opacity: 0;
		letter-spacing: -0.045em;
	}

	.hero-sub {
		font-size: 18px;
		color: hsla(0,0%,100%,.65);
		max-width: 600px;
		margin: 0 auto 40px;
		line-height: 1.6;
		opacity: 0;
		font-weight: 500;
	}

	.hero .cta-primary { opacity: 0; }

	/* ===== LOGOS STRIP ===== */
	.logos-strip {
		padding: 60px 0;
		border-top: 1px solid rgba(255,255,255,0.04);
		border-bottom: 1px solid rgba(255,255,255,0.04);
		background: rgba(255,255,255,0.01);
		overflow: hidden;
	}

	.logos-label {
		text-align: center;
		font-size: 11px;
		text-transform: uppercase;
		letter-spacing: 4px;
		color: hsla(0,0%,100%,.4);
		font-weight: 600;
		margin-bottom: 32px;
	}

	.logos-track {
		overflow: hidden;
		mask-image: linear-gradient(90deg, transparent, #000 10%, #000 90%, transparent);
		-webkit-mask-image: linear-gradient(90deg, transparent, #000 10%, #000 90%, transparent);
	}

	.logos-row {
		display: flex;
		gap: 64px;
		align-items: center;
		animation: logoScroll 40s linear infinite;
		width: max-content;
	}

	.logos-row img {
		height: 32px;
		width: auto;
		filter: brightness(0) invert(1);
		opacity: 0.5;
		transition: opacity .3s ease;
		flex-shrink: 0;
	}

	.logos-row img:hover {
		opacity: 1;
	}

	@keyframes logoScroll {
		from { transform: translateX(0); }
		to { transform: translateX(-50%); }
	}

	/* ===== STATS ===== */
	.stats-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 24px;
	}

	.stat {
		text-align: center;
		padding: 32px 16px;
		background: rgba(255,255,255,0.03);
		border: 1px solid rgba(255,255,255,0.06);
		border-radius: 16px;
		transition: all .4s cubic-bezier(.22,1,.36,1);
	}

	.stat:hover {
